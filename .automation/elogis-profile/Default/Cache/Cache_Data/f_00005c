 						clickedPolygonMarker.push(oPolygonMarker);
 					}

 					if(clickedPolygonLatLng.length >= 3){
 						doCallbackGetPointPolygon();
 					}
 				}
 			}
 		});

 		var overlapCoverMarker = null;

 		naver.maps.Event.addListener(recognizer, 'overlap', function(list) {
