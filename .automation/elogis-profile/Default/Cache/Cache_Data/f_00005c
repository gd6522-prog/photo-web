		//선택 노선 배경색 설정
		function doSetCellRouteBgColor(objSheet, maxCount) {
			var selectIdx = 0;

			for(var i=grid.doGetStartDataIndex(objSheet);i<=grid.doGetEndDataIndex(objSheet);i++){
				var selected = objSheet.GetCellValue(i, 'IS_ROUTE');
				if (selected == '1'){

					if (0 > maxCount){
						if (objSheet.GetCellValue(i, 'POINT_CNT') > 0){
							objSheet.SetCellBackColor(i, 'IS_ROUTE', colorArr[(selectIdx>9)?10:selectIdx++]);
						}
					}
					else if (selectIdx < maxCount){
						if (objSheet.GetCellValue(i, 'POINT_CNT') > 0){
							objSheet.SetCellBackColor(i, 'IS_ROUTE', colorArr[(selectIdx>9)?10:selectIdx++]);
						}
					}
					else{
						objSheet.SetCellValue(i, 'IS_ROUTE', '0');
						objSheet.SetCellBackColor(i, 'IS_ROUTE', '');
					}
				}
				else{
					objSheet.SetCellBackColor(i, 'IS_ROUTE', '');
				}
			}
		}


