		//전송, 최적화 처리전 화면 데이터 검증
		function doGetRouteIdPreProcess(msg, flag, isPointChk, exMsg){

			var isProcess = false;

			if (!doGetPreProcess(flag)){
				return '';
			}

			var selectRouteIds = doGetSelectRouteIds('', '', -1, isPointChk);

			if ('' == selectRouteIds){
				alert('선택된 노선이 없습니다.');
				return '';
			}else if(msg=="최적화"){
				isProcess = true;
			}else{
				isProcess = confirm('선택된 노선을 ['+msg+'] 하겠습니까?' + ('' == exMsg ? '' : ('\n' + exMsg)));
			}

			return isProcess ? selectRouteIds : '' ;
		}


		//선행 체크 프로세스
		function doGetPreProcess(flag){

			for(var i=grid.doGetStartDataIndex(IBSHEET01);i<=grid.doGetEndDataIndex(IBSHEET01);i++){
				var select = IBSHEET01.GetCellValue(i, 'IS_ROUTE');
				if (select == '1'){
					if (IBSHEET01.GetCellValue(i, 'DELETE_RT') =='1' && flag != 'REMOVE_ROUTE' ){
		    	  		alert('삭제된 차량이 포함되어 있습니다.('+IBSHEET01.GetCellValue(i, 'ROUTE_ID')+')');
		    	  		return false;
		    	  	}
					else if (IBSHEET01.GetCellValue(i, 'AVLNOTC_CNT') > 0){
		    	  		alert('배송이 시작된 차량이 포함되어 있습니다.('+IBSHEET01.GetCellValue(i, 'ROUTE_ID')+')');
		    	  		return false;
		    	  	}
					else if (IBSHEET01.GetCellValue(i, 'PLAN_CFM_ID') != '' && (flag == 'OPTIMIZE_ROUTE' || flag == 'DRAFT_CONFIRM' || flag == 'PLAN_CONFIRM' || flag == 'REMOVE_ROUTE' || flag == 'ASSIGN_VHCL' || flag == 'OPTIMIZE_TIME' || flag=='STRAIGHT_LINE' || flag == 'CLEAR_TIME'|| flag == 'CLEAR_VHCL')){
		    	  		alert('배차확정된 차량이 포함되어 있습니다.('+IBSHEET01.GetCellValue(i, 'ROUTE_ID')+')');
		    	  		return false;
		    	  	}
					else if (IBSHEET01.GetCellValue(i, 'PLAN_CFM_ID') == '' && flag == 'PLAN_CANCEL'){
		    	  		alert('배차확정되지 않은 차량이 포함되어 있습니다.('+IBSHEET01.GetCellValue(i, 'ROUTE_ID')+')');
		    	  		return false;
		    	  	}
					else if (IBSHEET01.GetCellValue(i, 'VHCL_NO') == '' && (flag == 'DRAFT_CONFIRM' || flag == 'PLAN_CONFIRM')){
		    	  		alert('차량이 지정되지 않은 노선이 있습니다.('+IBSHEET01.GetCellValue(i, 'ROUTE_ID')+')');
		    	  		return false;
					}
					else if (IBSHEET01.GetCellValue(i, 'STOP_CNT') == '0' && (flag == 'DRAFT_CONFIRM' || flag == 'PLAN_CONFIRM')){
		    	  		alert('배송처가 없는 차량은 확정할 수 없습니다.('+IBSHEET01.GetCellValue(i, 'ROUTE_ID')+')');
		    	  		return false;
		    	  	}
				}
			}

			return true;
		}


		//최적화 옵션 팝업 열기
		function doOpenOptionPopup(){

	        // 화면의 높이와 너비를 변수로 만듭니다.
	        var maskHeight = $(document).height();
	        var maskWidth = $(window).width();

	        // 마스크의 높이와 너비를 화면의 높이와 너비 변수로 설정합니다.
	        $('.popup_mask').css({'width':maskWidth,'height':maskHeight});

	        // fade 애니메이션 : 1초 동안 검게 됐다가 80%의 불투명으로 변합니다.
	        //$('.popup_mask').fadeIn(1000);
	        $('.popup_mask').fadeTo("slow",0.5);

	        // 레이어 팝업을 가운데로 띄우기 위해 화면의 높이와 너비의 가운데 값과 스크롤 값을 더하여 변수로 만듭니다.
	        var left = ( $(window).scrollLeft() + ( $(window).width() - $('.option_window').width()) / 2 );
	        var top = ( $(window).scrollTop() + ( $(window).height() - $('.option_window').height()) / 2 ) - 40;

	        // css 스타일을 변경합니다.
	        $('.option_window').css({'left':left,'top':top, 'position':'absolute'});

	        // 레이어 팝업을 띄웁니다.
	        $('.option_window').show();
	    }


