		function IBSHEET03_OnDropEnd(FromSheet, FromRow, ToSheet, ToRow, X, Y, Type) {

			if (ToSheet.RowCount() > 0){
				if (Number(ToSheet.GetCellValue(ToRow, 'AVLNOTC_CNT')) > 0){
					alert("출발보고된 차량에는 주문을 추가할 수 없습니다.(CASE 1)");
