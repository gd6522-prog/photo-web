		//선택된 노선 리턴
		function doGetSelectRouteIds(notAssign, appendRoute, maxCount, isPointCnt){

			var routeIds = '';
			var cnt = 0;

			//지도 연동 여부
			//if ($('input:checkbox[id="map_event"]').is(":checked")){
				for(var i=grid.doGetStartDataIndex(IBSHEET01);i<=grid.doGetEndDataIndex(IBSHEET01);i++){
					var select = IBSHEET01.GetCellValue(i, 'IS_ROUTE');
					if (select == '1'){
						if ((cnt < maxCount && 0 <= maxCount) || 0 > maxCount){
							if (isPointCnt){
								if (IBSHEET01.GetCellValue(i, 'POINT_CNT') > 0){
									routeIds += IBSHEET01.GetCellValue(i, 'NODE_ID') + "|";
									cnt++;
								}
							}
							else{
								routeIds += IBSHEET01.GetCellValue(i, 'NODE_ID') + "|";
								cnt++;
							}
						}
					}
				}

				if (appendRoute!='' && routeIds.indexOf(appendRoute)<0){
					routeIds += appendRoute + "|";
				}

				routeIds += notAssign;

			return routeIds;
		}


