	    var latSpan = northEast.lat() - southWest.lat();

	    if (oMarkerAlone != null){    oMarkerAlone.setPosition(new naver.maps.LatLng(37.545338, 127.05042));}else{    oMarkerAlone = new naver.maps.Marker({        position: naver.maps.LatLng(37.545338, 127.05042)      , map: oMap      , title: ''      , clickable: true      , icon: {            url: '/images/planx/map/img_location.png'          , size: new naver.maps.Size(20, 27)          , origin: new naver.maps.Point(0, 0)          , anchor: new naver.maps.Point(10, 14)        }   });}naver.maps.Event.addListener(oMarkerAlone, 'rightclick', function(e) {    doMapPanoramaView(oMarkerAlone, e);});

 		naver.maps.Event.addListener(oMap, 'mousemove', function(e) {

 			var oPoint = e.coord;

 			if(isDrawAreaEllipse && clickedEllipseLatLng.length==1){

				if (oClickedEllipse == null || null == oClickedEllipse.getMap()){
					oClickedEllipse = new naver.maps.Ellipse({      map: oMap    , bounds: new naver.maps.LatLngBounds(		clickedEllipseLatLng[0],		new naver.maps.LatLng(oPoint.lat(), oPoint.lng()))    , strokeColor: '#8080ff'    , strokeOpacity: 0.6    , strokeWeight: 1    , fillColor: '#8080ff'    , fillOpacity: 0.2});
				}
				else{
					oClickedEllipse.setBounds(new naver.maps.LatLngBounds(		clickedEllipseLatLng[0],		new naver.maps.LatLng(oPoint.lat(), oPoint.lng())));
				}
 			}

 			if(isDrawAreaRectangle && clickedRectangleLatLng.length==1){
				if (oClickedRectangle == null || null == oClickedRectangle.getMap()){
					oClickedRectangle = new naver.maps.Rectangle({      map: oMap    , bounds: new naver.maps.LatLngBounds(		clickedRectangleLatLng[0],		new naver.maps.LatLng(oPoint.lat(), oPoint.lng()))    , strokeColor: '#8080ff'    , strokeOpacity: 0.6    , strokeWeight: 1    , fillColor: '#8080ff'    , fillOpacity: 0.2});
				}
				else{
					oClickedRectangle.setBounds(new naver.maps.LatLngBounds(		clickedRectangleLatLng[0],		new naver.maps.LatLng(oPoint.lat(), oPoint.lng())));
				}
 			}
 		});


 		naver.maps.Event.addListener(oMap, 'click', function(e) {

 			var oPoint = e.coord;

 			if ('IN' == wayDirection){
				oMarkerAlone.setPosition(e.coord);
				doMapReturnLatLng(oPoint.lat(), oPoint.lng(), '');
				if(typeof(clickMarkerCall) == 'function' ) {
					clickMarkerCall(oPoint.lat(), oPoint.lng());
				}
 			}
 			else{
 				if(isDrawAreaRectangle){

 					doMapSetInfoWindow('');

 					if(clickedRectangleLatLng.length >= 2){
 						clickedRectangleLatLng = new Array();
 					}

 					clickedRectangleLatLng.push(new naver.maps.LatLng(oPoint.lat(), oPoint.lng()));

 					if(clickedRectangleLatLng.length >= 2){
 						doCallbackGetPointRectangle();
 					}
 				}
 				else if(isDrawAreaEllipse){

 					doMapSetInfoWindow('');

 					if(clickedEllipseLatLng.length >= 2){
 						clickedEllipseLatLng = new Array();
 					}

 					clickedEllipseLatLng.push(new naver.maps.LatLng(oPoint.lat(), oPoint.lng()));

 					if(clickedEllipseLatLng.length >= 2){
 						doCallbackGetPointEllipse();
 					}
 				}
 				else if(isDrawAreaPolygon){

 					doMapSetInfoWindow('');

 			    	clickedPolygonLatLng.push(new naver.maps.LatLng(oPoint.lat(), oPoint.lng()));

 					if (oClickedPolygon != null){
 						oClickedPolygon.setMap(null);

 			        	for (i=0;i<clickedPolygonMarker.length;i++){
 			        		clickedPolygonMarker[i].setMap(null);
 			        	}
 					}

 					oClickedPolygon =  new naver.maps.Polygon({      map: oMap    , paths: [       	  clickedPolygonLatLng      ]    , fillColor: '#8080ff'    , fillOpacity: 0.2    , strokeColor: '#8080ff'    , strokeOpacity: 0.6    , strokeWeight: 1});

 					for (var i=0;i<clickedPolygonLatLng.length;i++){
