							alert("출발보고된 차량의 주문은 이동할 수 없습니다.(CASE 2)");
							return;
						}
						else if ('' != FromSheet.GetCellValue(i, 'PLAN_CFM_ID')){
							alert("배차완료된 차량의 주문은 이동할 수 없습니다.(CASE 2)");
							return;
						}
						else if ('1' == FromSheet.GetCellValue(i, 'DELETE_RT')){
							alert("배차완료된 차량의 주문은 이동할 수 없습니다.(CASE 2)");
							return;
						}
					}
				}


				var startIndex = grid.doGetStartDataIndex(ToSheet);
				var endIndex = (ToSheet.RowCount() + startIndex - 1);

				if (endIndex == ToRow){
					alert("귀소지 다음에는 배송지를 추가할 수 없습니다.");
