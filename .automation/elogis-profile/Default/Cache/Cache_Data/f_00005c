		//선택된 셀값 얻기
		function doGetSelectValues(objSheet, compareName, saveName){
			var selectValues = '';
			for(var i=grid.doGetStartDataIndex(objSheet);i<=grid.doGetEndDataIndex(objSheet);i++){
				var selected = objSheet.GetCellValue(i, compareName);
				if (selected == '1'){
					selectValues += objSheet.GetCellValue(i, saveName)+"|";
				}
			}

			//마지막 문자열 "|" 제거
			return selectValues.length>0 ? selectValues.substr(0, selectValues.length -1) : selectValues;
