				}
				else if ('1' == ToSheet.GetCellValue(ToRow, 'DELETE_RT')){
					alert("배차완료된 차량에는 주문을 추가할 수 없습니다.(CASE 1)");
					return;
				}

				for(var i=grid.doGetStartDataIndex(FromSheet);i<=grid.doGetEndDataIndex(FromSheet);i++){
					var selected = FromSheet.GetCellValue(i, 'IS_ORDER');
					if (selected == '1'){
