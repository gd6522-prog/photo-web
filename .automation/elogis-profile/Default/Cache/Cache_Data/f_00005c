		function IBSHEET01_OnLoadData(data){

			var saveNameArr = IBS_ConcatSaveName(IBSHEET01).split("|");
			var jsonData = $.parseJSON(data);
			var sdata = jsonData["Data"];

			if (sdata.length > 0){

				for(var i=0;i<sdata.length;i++){

					var lvl = sdata[i]['LVL'];
					var routeId = sdata[i]["NODE_ID"];
					var avlnotcCnt = sdata[i]['AVLNOTC_CNT'];
					var planCfmId = nvl(sdata[i]['PLAN_CFM_ID']);
					var partCancelYn = nvl(sdata[i]['PART_CANCEL_YN']);
					var dayOff = nvl(sdata[i]['DAYOFF_TYPE_CD']);


					var pointCnt = sdata[i]['POINT_CNT'];
					var arrivedDtm = nvl(sdata[i]['ARRIVED_DTM']);
					var leavedDtm = nvl(sdata[i]['LEAVED_DTM']);

					sdata[i]["NODE_NAME#Cursor"] = 'Pointer';
					sdata[i]["NODE_NAME#FontColor"] = '#0000ff';

					if (lvl == '1'){
						if (   Number(sdata[i]["MAX_RATE_AMT"]) > 100
							 ||Number(sdata[i]["MAX_RATE_RT"]) > 100
							 ||Number(sdata[i]["MAX_RATE_CBM"]) > 100
							 ||Number(sdata[i]["MAX_RATE_BOX"]) > 100
							 ||Number(sdata[i]["MAX_RATE_MUL"]) > 100){
							sdata[i]["FontColor"] = '#ff0000';
						}

						//상차검수된 경우
						if (avlnotcCnt > 0){
							sdata[i]["BackColor"] = '#FFFFAA';
						}

						//확정되지 않은 것 && //저장 권한이 있는 경우만 가능
						else if ('' == planCfmId && '1' == '1'){
							sdata[i]["NODE_CODE#Cursor"] = 'Pointer';
							sdata[i]["NODE_CODE#FontColor"] = '#0000ff';
						}

						sdata[i]["IS_ORDER#Edit"] = false;

						for(var c=0;c<saveNameArr.length;c++){
							sdata[i][saveNameArr[c]+"#FontBold"] = true;
						}

						if (jsonData["Etc"]["selectRouteIds"].indexOf(routeId)>=0){
							sdata[i]['IS_ROUTE'] = 1;

						}

						if(dayOff != ''){
							sdata[i]["VHCL_NM#BackColor"] = '#FF803E'
						}

						sdata[i]["NODE_NAME#ToolTip"] = sdata[i]["MST_ROUTE_ID"]+"("+sdata[i]["ROUTE_ID"]+")";
						sdata[i]["DRV_NM#ToolTip"] = sdata[i]["DRV_NO"];
					}
					else if (lvl == '2'){

						sdata[i]["IS_ROUTE#Edit"] = false;

						if (avlnotcCnt > 0 || '' != planCfmId){ //출발했거나 확정되었거나
							sdata[i]["IS_ORDER#Edit"] = false;
						}

						sdata[i]["NODE_NAME#ToolTip"] = sdata[i]["ORDER_GRP_SEQ"];
					}

						//거리 또는 시간이 없는 경우, 부분 확정 취소된 경우
					if ((arrivedDtm == '' || leavedDtm == '' || partCancelYn == 'Y') && pointCnt > 0){
						for(var c=0;c<saveNameArr.length;c++){
							sdata[i][saveNameArr[c]+"#FontItalic"] = true;//!!!!!!
						}
					}

					if (avlnotcCnt > 0 || '' != planCfmId){ //출발했거나 확정되었거나
						delete sdata[i]["NODE_NAME#FontColor"];
						sdata[i]["FontColor"] = '#999999';
					}
				}

				var selectIdx = 0;
				var routeIdArr = doMapGetSelectRouteIds().split('|');

				for(var i=0;i<sdata.length;i++){
					var lvl = sdata[i]["LVL"]; //IBSHEET01.GetCellValue(i, 'LVL');
					if (lvl == '1'){
						//sdata[i]["IS_ROUTE#BackColor"] = '';
						if ($('input:checkbox[id="map_event"]').is(":checked")){
							if ('1' == sdata[i]['IS_ROUTE']){
								for(var j=0;j<=routeIdArr.length;j++){
									if (routeIdArr[j] == sdata[i]['ROUTE_ID']){
										sdata[i]["IS_ROUTE#BackColor"] = colorArr[(selectIdx>=10)?11:selectIdx++];
									}
								}
							}
						}
					}
				}
			}

			return jsonData;
		}


		function IBSHEET01_OnSearchEnd(Code, Msg, StCode, StMsg, Response) {

			if (Code == 0){
				if ('1' == IBSHEET01.GetEtcData("treeChild")){
					//alert('child');
				}
				else{
					if (IBSHEET01.RowCount() > 0){
						IBSHEET01.ShowTreeLevel(0, 1);
						for(var i=grid.doGetStartDataIndex(IBSHEET01);i<=grid.doGetEndDataIndex(IBSHEET01);i++){

							var lvl = IBSHEET01.GetCellValue(i, 'LVL');
							var routeId = IBSHEET01.GetCellValue(i, "NODE_ID");

							if (lvl == '1'){

								if (IBSHEET01.GetEtcData("selectRouteIds").indexOf(routeId)>=0){
									if (routeId == doMapGetFocusRouteId()){
										IBSHEET01.SetRowExpanded(i, 1);
										IBSHEET01.SetSelectRow(i);
										IBSHEET01.SetTopRow(i);
									}
								}
							}
						}
					}
				}

				doRetrieveIBSHEET03();
				doRetrieveSummary();
			}

			IS_RETRIEVING_SHEET01 = false;
