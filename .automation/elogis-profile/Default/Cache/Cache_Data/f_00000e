Ext.define('VC.components.CustomExcelUploadPop',{
	statics : {
		show : function(param){
			var popGrid = Ext.create('VC.grid.CommonGrid', {
				itemId : '__customExcelUploadPopGrid__',
				titleText : Util.nvl(param.titleText, ''),
				editable : Util.nvl(param.editable, false),
				updateOnly : true,
				region : 'center',
				selectionMode : Util.nvl(param.SELECTIONMODE, 'SINGLE'),
				userColumnSave : false,				//컬럼 개인화 버튼 Active
				columnDefine : param.columnDefine,
				//buttonsConfig: param.buttonsConfig,
				buttonsConfig: [
					{text: 'SAVE', iconCls : Util.buttonClsConfig('SAVE',''), handler : function(){this.up('[xtype=window]').saveAndSearch();}},
					{text: 'DELETE', iconCls : Util.buttonClsConfig('DELETE',''), handler : function(){this.up('[xtype=window]').remove();}},
					{text: 'RESET', iconCls : Util.buttonClsConfig('RESET','icon-apply'), handler : function(){this.up('[xtype=window]').reset();}},
					{text: 'CANCEL', iconCls : Util.buttonClsConfig('CANCEL',''), handler : function(){this.up('[xtype=window]').close();}},
					{text : 'UPLOAD',
						menu : [
							{
								text : 'DOWN_EXCEL_TEMPLATE',
								iconCls : Util.buttonClsConfig('DOWNLOAD'),
								handler : function(){this.up('[xtype=window]').downExcelTemplate();}
							},
							{
								text : 'UP_EXCEL_TO_GRID',
								iconCls : Util.buttonClsConfig('UPLOAD'),
								handler : function(){this.up('[xtype=window]').upExcelDataToGrid();}
							}
						]
					}
				],
				editorConfig : Util.nvl(param.editorConfig, {}),
				validator : Util.nvl(param.validator, {}),
				listeners : Util.nvl(param.listeners, {})
			});

			//엑셀 업로드 데이타 유효성 체크
			if(!Util.isNull(param.loadData)) {
				popGrid.loadData = param.loadData;
			}

			//윈도우 띄우기
			return Ext.create('Ext.window.Window', {
				title: Util.nvl(Util.nvl(param.COLUMNDESCR_LANG, Lang.get(param.TITLE)),'NEW'),
				constrainHeader: true,
				autoShow : true,
				modal : true,
				width : param.width,
				height : param.height,
				layout : 'fit',
				hasReturnVal : false,
				listeners : {
					afterrender : function(){
						var me = this;
						Ext.defer(function(){
							var grid = Ext.getCmp('__customExcelUploadPopGrid__');
							//grid.loadExcelData();
							grid.openUploadAndReadExcelPopup();
						},500);
					},
					close : function(){
						var me = this;
						popGrid.store.removeAll();
					}
				},
				items : [
					{
						xtype : 'container',
						name : 'windowContent',
						layout : 'border',
						items : [
							popGrid
						]
					}
				],
				//저장
				saveAndSearch : function(){
					var me = this;
					var grid = Ext.getCmp('__customExcelUploadPopGrid__');
					grid.saveAndSearch(viewPort, param.saveURL, {}, param.searchFunc, param.confirmYn);
				},
				//삭제
				remove : function(){
					var me = this;
					var grid = Ext.getCmp('__customExcelUploadPopGrid__');
					var store = grid.getStore();
					if(grid.lastSelectedRowIdx > -1) {//선택한 행 Index
						store.removeAt(grid.lastSelectedRowIdx);//선택한 행 Index의 레코드 제거
						//그리드 레코드 건수 표시
						Ext.getCmp(grid.id + "DataCount").setText(Lang.get(grid.titleText)+' : ' + store.getData().length);
					}
				},
				//초기화
				reset : function(){
					var me = this;
					var grid = Ext.getCmp('__customExcelUploadPopGrid__');
					grid.clear();
				},
				//엑셀 업로드용 템플릿 다운
				downExcelTemplate : function(){
					var me = this;
					var grid = Ext.getCmp('__customExcelUploadPopGrid__');
					grid.downExcelSearch();
				},
				//엑셀 데이터 그리드에 로드
				upExcelDataToGrid : function(){
					var me = this;
					var grid = Ext.getCmp('__customExcelUploadPopGrid__');
					//grid.loadExcelData();
					grid.openUploadAndReadExcelPopup();
				}
			});
		}
	}
});

function customPickCellPop(param)
{
	//팝업창의 조회조건. 상품코드, 상품명
	var searchConditionDS = [
		{
			TYPE		: 'FIELD',
			DATATYPE	: 'STRING',
			DBCOLUMN	: 'WCELL_NO',
			COLUMNDESCR : 'WCELL_NO',
