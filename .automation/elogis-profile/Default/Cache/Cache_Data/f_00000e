                //popGrid의 search를 실행함
                popGrid.search(popWin, '/wmsCommonService/search', params);
            },
            closeAndReturn: function () {
                var me = this;
                me.hasReturnVal = true;
                var grid = this.down('grid');
                var selRows = grid.getSelectionModel().getSelection();
                
                //체크박스 선택 없을때
                if(selRows.length == 0){
                    Ext.MessageBox.show({
                        msg: Lang.get('NO_ROW_SELECTED'),
                        buttons: Ext.MessageBox.OK,
                        icon: Ext.MessageBox.INFO
                    });
                    return;
                }
                
                //선택한 대상 SET (다중선택 가능)
                var ret = [];
                var nm = [];
                
                if (params.PARAM10 == 'N') { //조회조건 외 호출일 경우
                    for (var i = 0; i < selRows.length; i++) {
                        ret.push(selRows[i].data);
                    }
                    param.afterGetRow(ret);
                    me.close();
                } else {
                    for (var i = 0; i < selRows.length; i++) {
                        ret.push(selRows[i].data.ITEM_CD);
                        nm.push(selRows[i].data.ITEM_NM);
                    }
                    if (param.CALLBY && param.CALLBY.onPopClose) {
                        param.CALLBY.onPopClose(ret, nm);
                        me.close();
                    } else {
                        Ext.defer(function() { me.close() }, 100);
                    }
                }
            }
        }).show();
    });
}

