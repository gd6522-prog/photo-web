//즐겨찾기 저장 콜백
function doSaveFavoritesCallBack(json){
    var result = json.result;
    var mode = json.crud;
    var menuId = json.menuId;
    
    if(result == "SUCCESS"){
       if(mode == "I"){
           doFavoritesList();
           
           alert("즐겨찾기 추가 되었습니다.");
      
           $("#span_"+menuId).addClass("active");
           
       }else{
           $("#li_f_"+menuId).remove();
           $("#span_"+menuId).removeClass("active");
           alert("즐겨찾기 삭제 되었습니다.");   
       }
    }else{
       alert("즐겨찾기 추가/삭제 실패했습니다.");
    }
}




//메뉴 tab클릭
function doFavoritesList(){
    var o = {
                url:'/main/MainPage/leftMenu/favorites/retrieve.do',
                param: {},
                callback:doFavoritesListCallBack
            };
   
    
    callService(o); 
    
    $("#fav_list").html("");
}


function doFavoritesListCallBack(json){
    
    $("#fav_list").html("");
    
    var result = json.result;
    if(result == "SUCCESS"){
        $("#fav_list").html(json.favoritesTree);
    }
}


