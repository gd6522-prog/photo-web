	/**
	 * 왼쪽 메뉴에서 클릭해 사용
	 */
	function movePage(menuCategory, menuId, menuLvl, menuLink, menuNm, oParam) {
 		var base_path = "";
		var url = base_path + menuLink;

		//Selector Text => title 가져오기
		//var title = $("li.on > a").text();
		var title = menuNm;

		//이미 열린 페이지가 있는지 확인
		var tabid = myTab.FindTabID(menuId);
		if (url !== "" && tabid === -1) {

			var idx = myTab.InsertItem2(menuId, title, "");
			var frm = document.getElementById("form_hidden");

			frm.menu_category.value=menuCategory;
			frm.menu_id.value=menuId;
			frm.menu_lvl.value=menuLvl;
			frm.action = menuLink;

			var ifrm = myTab.GetTabIframe(idx);
	 		frm.target = ifrm.name;
	 		frm.submit();
		} else {
	    	myTab.SetSelectedIndex(tabid);
	    	try{
	    		window[tabid].doCallbakInjectParameter(oParam);// = IBTabs[TabID]
	    	}
	    	catch(e){
	    	}
	    }

	}

