			var d4 = vhclNo.substring(5, 9);	// 숫자이어야 함
			
			// 판독
			bool   = VHCL_NO_AREA.indexOf("," + d1 + ",") < 0 || isNaN(d2) == true || VHCL_NO_STR.indexOf("," + d3 + ",") < 0 || isNaN(d4) == true ? false : true;
		}
	}
	
	return bool;
}


