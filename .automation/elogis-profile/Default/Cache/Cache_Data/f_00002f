/**
 * 숫자, 실수형만 입력 가능하도록 Text필드 Keyup체크
 */
function doInitInputTypeSet(){
	$("input:text[numberOnly]").on("keyup", function() {
	    $(this).val($(this).val().replace(/[^0-9]/g,""));
	});

	$("input:text[floatOnly]").on("keyup", function() {
	    
		 $(this).val($(this).val().replace(/[^(0-9|.)]/g,""));
		 
		 var value = $(this).val();				
		 var count = 0;
		 var ch;
		 
		 for(i=0; i<value.length; i++) {
		  ch = value.charAt(i);
		  
		  if(isNaN(ch)) {
		   if(ch == ".") {
		    count++;
		   }
		  }    
		 }
		 
		 if(count > 1) {
			 $(this).val( $(this).val().slice(0,-1) );
		 } 
		 
		 
	});
	
}

/**
 * 검색 날짜 조건 체크
 * 
 * param - sDate : 시작날짜 (yyyy-mm-dd)
 * 		   eDate : 종료날짜 (yyyy-mm-dd)
 * 		   sDay  : 시작일 설정 값 (int)
 * 		   eDay  : 종료일 설정 값 (int)
 * 		   gDay  : 사이값 설정 값 (int)
 * 
 */
function checkValidSearchDate(param){
	if((typeof(param.sDate) == undefined ? '' : param.sDate) == ''){
		
		alert("시작일을 지정해 주십시오.");
		
		return false;
	}
	
	var reslt = true;
	
	var sDate = (typeof(param.sDate) ==  'undefined') ? '' : param.sDate;
	var eDate = (typeof(param.eDate) ==  'undefined') ? '' : param.eDate;
	var sDay  = (typeof(param.sDay)	 ==  'undefined') ? '' : -param.sDay;
	var eDay  = (typeof(param.eDay)  ==  'undefined') ? '' : param.eDay;
	var gDay  = (typeof(param.gDay)  ==  'undefined') ? '' : param.gDay;
	
	var cDate = $.trim(getDate(null));						// 현재날짜
	var setFromDate = getBeforeNextDate(cDate, sDay);		// 설정 시작 날짜
	var setToDate = getBeforeNextDate(cDate, eDay);			// 설정 종료 날짜
	
	//시작날짜와 종료날짜 존재
	if(eDate != ''){
		
		var dateTerm = getDateTerm(sDate, eDate);			// 시작날짜 ~ 종료날짜
		
		// 시작일보다 종료일이 큰 경우
		if(dateTerm < 0){
			alert('시작일이 종료일보다 클 수가 없습니다.');
			return false;
		}
		// 시작일과 종료일이 0으로 설정되어있는 경우
		if((sDay === 0 && eDay === 0) && (sDate < setFromDate || eDate > setToDate)){
			alert('오늘만 조회 가능합니다.');
			return false; 
		}
		
		// 시작일과 종료일이 설정되어있는경우
		if((sDay !== '' && eDay !== '') && (sDate < setFromDate || eDate > setToDate)){
			alert('조회기간은 ' + setFromDate + ' 부터 ' + setToDate + '까지 가능합니다.');
			return false; 
		}
		// 시작일만 설정되어있는 경우
		else if((sDay !== '' && eDay === '') && sDate < setFromDate){
			alert('조회기간은 ' + setFromDate + ' 부터 가능합니다.');
			return false; 
		}
		// 종료일만 설정되어있는 경우
		else if((sDay === '' && eDay !== '') && eDate > setToDate){
			alert('조회기간은 ' + setToDate + ' 까지 가능합니다.');
			return false; 
		}
		// 시작일 ~ 종료일 사이값이 설정 값보다 큰 경우
		else if(gDay != 0 && dateTerm > gDay){
			alert('시작일과 종료일 사이는 최대 ' + gDay + '일까지만 가능합니다. ');
			return false;
		}
		
		
	}
	
	// 시작날짜만 존재
	if(eDate == ''){
		
		var dateTerm = getDateTerm(cDate, sDate);	// 현재날짜 - 시작날짜
		
		// 시작일과 종료일이 0으로 설정되어있는 경우
		if((sDay === '' && eDay === '') && (dateTerm < sDay || dateTerm > eDay)){
			alert('오늘만 조회 가능합니다.');
			return false; 
		}
		// 시작일과 종료일이 설정되어있는경우
		else if((sDay !== '' &&  eDay !== '') && (dateTerm < sDay || dateTerm > eDay)){
			alert('조회기간은 ' + setFromDate + ' 부터 ' + setToDate + '까지 가능합니다.');
			return false;
		}
		// 시작일만 설정되어있는 경우
		else if(eDay === '' && dateTerm < sDay){
			alert('조회기간은 ' + setFromDate + ' 부터 가능합니다.');
			return false; 
		}
		// 종료일만 설정되어있는 경우
		else if(sDay === '' && dateTerm > eDay){
			alert('조회기간은 ' + setToDate + ' 까지 가능합니다.');
			return false; 
		}
		
	}
	
	return reslt;
}


//로딩바
function fnShowLoading(flag) {

	if(flag) {
		// 화면의 높이와 너비를 변수로 만듭니다.
     var maskHeight = $(document).height();
     var maskWidth = $(window).width();

     // 마스크의 높이와 너비를 화면의 높이와 너비 변수로 설정합니다.
     $('.showLoading_mask').css({'width':maskWidth, 'height':maskHeight});
     $('.showLoading_mask').fadeTo("fast", 0.5);
	}
	else {
		$('.showLoading_mask').hide();
	}
}
