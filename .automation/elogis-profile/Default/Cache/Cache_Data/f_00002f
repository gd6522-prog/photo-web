/**
 * target 문자열이 null이면 대체문자열로 치환
 * @param target
 * @param replace
 * @returns {String}
 */
function nvl(target, replace) {
	
	// return할 값
    var str = "";
    
    try {
    	
    	// target문자열 앞뒤 공백제거
    	var strr = $.trim(target);
    	
    	// null이면 대체문자열로 retun
    	if(!strr || strr == null || strr == "" || strr == "null" || strr == "undefined" || strr == undefined || strr == "") {
    		
    		str = replace;
    	}
    	
    	// 아닌 경우 원래문자열 return
    	else {
    		
    		str = target;
    	}
    }
    
    catch(err) {
    	
    	str = replace;
    }
    
    return str;
}


/**
 * replaceAll 함수
 * @param str
 * @param target
 * @param replace
 * @returns
 */
function replaceAll(str, target, replace) {

	return str.split(target).join(replace);
}


/**
 * target 날짜객체의 날짜 형식 맟추기 YYYY-MM-DD
 * @param target
 */
function getDate(target) {
	
	// target 날짜가 null이면 오늘날짜 구하기
	if(target == null) {
		
		target = new Date();
	}
	
	// 날짜 얻기
	var y = target.getFullYear();
	var m = addZero(target.getMonth() + 1);
	var d = addZero(target.getDate());
	
	return y + "-" + m + "-" + d;
}



/**
 * target 날짜 beforeNext 일 전, 일 후 날짜 구하기 
 * @param target
 * @param beforeNext
 * @returns {String}
 */
function getBeforeNextDate(target, beforeNext) {
	
	// 이전, 이후 날짜
	var newDate = null;
	
	// target날짜 년, 월, 일 구하기
	var y       = Number(target.split("-")[0]);
	var m       = Number(target.split("-")[1]);
	var d       = Number(target.split("-")[2]);
	
	// beforeNext값이 0, 양수이면 이 후 날짜
	if(beforeNext >= 0) {
		
		newDate = new Date(y, m - 1, d + Number(Math.abs(beforeNext)));
	}
	
	// 음수면 이 전 날짜
	else {
		
		newDate = new Date(y, m - 1, d - Number(Math.abs(beforeNext)));
	}
	
	return getDate(newDate);
}

/**
 * target 날짜 beforeNext 달 전, 달 후 날짜 구하기
 * @param target
 * @param beforeNext
 * @returns {String}
 */
function getBeforeNextMonth(target, beforeNext) {
	
	// 이전, 이후 날짜
	var newDate = null;
	
	// target날짜 년, 월, 일 구하기
	var y       = Number(target.split("-")[0]);
	var m       = Number(target.split("-")[1]);
	var d       = Number(target.split("-")[2]);
	
	// beforeNext값이 0, 양수이면 이 후 날짜
	if(beforeNext >= 0) {
		
		newDate = new Date(y, (m - 1) + Number(Math.abs(beforeNext)), d);
	}
	
	// 음수면 이 전 날짜
	else {
		
		newDate = new Date(y, (m - 1) - Number(Math.abs(beforeNext)), d);
	}
	
	return getDate(newDate);
}

/**
 * 두 날짜간 날짜 계산
 * @param sdate : 시작일자
 * @param edate : 종료일자
 * @returns {Number}
 */
function getDateTerm(sdate, edate) {
	
	// 시작일자 배열
	var sdateArr = sdate.split("-");
	
	// 종료일자 배열
	var edateArr = edate.split("-");
	
	// Date객체
	var sdateObj = new Date(sdateArr[0], Number(sdateArr[1]) - 1, Number(sdateArr[2]));	// 시작일자
	var edateObj = new Date(edateArr[0], Number(edateArr[1]) - 1, Number(edateArr[2]));	// 종료일자
	
	// 두 날짜간 일 수 계산
	var betDate  = (edateObj.getTime() - sdateObj.getTime()) / (1000 * 60 * 60 * 24);
	
	return betDate;
}


/**
 * HashMap, Array 사이즈, 문자열 길이 구하기
 * @param obj
 * @returns {Number}
 */
function getSize(obj) {
	
	// size return값
	var size = 0;
	
	try {
		
		// HashMap
		if(obj instanceof HashMap) {
			size = obj.size();
		}
		
		// Array, String
		else {
			size = obj.length;
		}
	}
	
	catch(err) {
		// 에러발생시 size는 0으로 간주
		size = 0;
	}
	
	return size;
}



/**
 * 0을 붙여 두자리수로 만들어주는 함수 (날짜형식에 사용)
 * @param target 
 */
function addZero(target) {
	
	// 숫자로 변환
	var num = Number(target);
	
	// 9와 대소비교
    var str = num > 9 ? num : "0" + num;
    
    return str.toString();
}


/**
 * 두 값 중 min값 찾기
 * @param t1
 * @param t2
 */
function min(t1, t2) {
	
	if(t1 < t2)      { return t1; }
	else if(t1 > t2) { return t2; }
	else             { return t1; }
}

/**
 * 두 값 중 max값 찾기
 * @param t1
 * @param t2
 */
function max(t1, t2) {
	
	if(t1 < t2)      { return t2; }
	else if(t1 > t2) { return t1; }
	else             { return t1; }
}


/**
 * 1000자리마다 콤마 찍기
 * @param obj
 * @returns {String}
 */
function setComma(target) {
	
	// Target 값
    var value     = target + "";
    
    // minus값 판독
    var minus     = value.indexOf("-") > -1 ? "-" : "";
    
    // 콤마를 찍어 return할 값
    var retValue  = "";
    
    // 소수점인지 체크
	var dot       = value.indexOf(".") > -1;
	
	// 값
	var value1    = dot == true ? value.split(".")[0] : value;
	var value2    = dot == true ? "." + value.split(".")[1] : "";
    
	// 해당 값
    var cellvalue = value1.replace(" ", "");
    
    // target값이 없는 경우 그대로 return
    if($.trim(cellvalue) == "" || cellvalue == "undefined") {
    	
        return target;
    }
    
    // 있는 경우에 콤마 처리
    else {
    	
    	// 글자 길이
    	var len   = getSize(cellvalue);
    	
        for(var i = 1 ; i <= len ; i++) {
        	
            if(i > 1 && (i % 3) == 1) {
            	
                retValue = cellvalue.charAt(len - i) + "," + retValue;
            }
            
            else {
            	
                retValue = cellvalue.charAt(len - i) + retValue;
            }
        }
    }
    
    return minus + retValue + value2;
}


/**
 * 숫자체크
 * @param target  : 객체
 * @param value   : 값
 * @param evtKey  : Event KeyCode
 * @param isComma : 1000단위 구분기호 여부
 * @param isZero  : 맨 앞 0허용 여부
 * @param isDot   : 소수점 가능 여부
 * @param isMinus : 음수 가능 여부
 */
function checkNumber(target, value, evtKey, isComma, isZero, isDot, isMinus) {
	
	// 콤마 제거 후 유효성 체크
	var val1 = replaceAll(value, ",", "");
	var chk  = isNaN(val1);
	
	// 마이너스만 입력시 허용인 경우 대기
	if(val1 == "-" && isMinus == true) { return; }
	
	// .만 입력시 허용인 경우 대기
	if(val1 == "." && isDot == true)   { return; }
	
	// 문자열 포함, 마이너스 허용불가인 경우 마이너스, 소수점 허용불가인 경우 소수점
	if(chk == true || (isMinus == false && Number(val1) < 0) || (isDot == false && val1.indexOf(".") > -1)) {
		
		alert("숫자만 입력할 수 있습니다.");
		target.blur();
		target.val("");
		target.focus();
	}
	
	// 천단위 구분기호 추가
	else {
		
		// 숫자입력, 백스페이스, Delete
		if((evtKey >= 48 && evtKey <= 57) || (evtKey >= 96 && evtKey <= 105) || evtKey == 8 || evtKey == 46) {
		
			// 값 세팅
			target.val(isComma == true ? setComma(Number(val1)) 
					                   : (isZero == true ? val1 
					                		   			 : Number(val1)));
		}
	}
}


/**
 * datepicker 세팅
 * @param targetId
 * @param targetImgId
 * @param minDateId
 */
function setDatepicker(targetId, targetImgId, minDateId) {
	
	// 이미지 Click시
	$("#" + targetImgId).click(function (e) {
		
		showDatePicker(targetId, minDateId);
		$("#ui-datepicker-div").css("z-index","9999");  //달력 최상단으로 수정
	});

	// 달력이미지에 cursor 속성 세팅
	$("#" + targetImgId).css("cursor", "pointer");
	
	// 포커스 아웃
	$("#" + targetId).blur(function (e) {
		
		datePickerFormat($(this), "O");
		
		// 최소날짜 세팅값이 있는 경우에만 실행
		if(minDateId != null) {
			
			// 최소날짜
			var minDate = minDateId == "TODAY" ? getDate(null) : (minDateId == null ? "" : replaceAll($("#" + minDateId).val(), "-", ""));
			var min     = Number(nvl(minDate, "0"));							    // 최소값
			var tar     = Number(nvl(replaceAll($(this).val(), "-", ""), "0"));	// 선택값
			
			// 값이 있는 경우만 비교
			if(min != 0 && tar != 0) {
				
				// 최소날짜보다 이전날짜 입력시 공백처리
				if(min > tar) {
					
					$(this).val("");
					alert("유효하지 않은 날짜 범위입니다.");
					$(this).focus();
				}
			}
		}
	});
	
	// 포커스 인
	$("#" + targetId).focus(function (e) {
		
		datePickerFormat($(this), "I");
	});
}

