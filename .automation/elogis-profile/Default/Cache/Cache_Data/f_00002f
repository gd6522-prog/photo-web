/**
 * 포커스 인, 아웃시 데이터 형태 결정
 * @param target
 * @param mode   : O(out), I(in)
 */
function datePickerFormat(target, mode) {
	
	// 값
	var val = nvl(target.val(), "");
	
	// 값이 있는 경우만 체크
	if(val != "") {
		
		// In
		if(mode == "I") {
			
			target.val(replaceAll(val, "-", ""));
		}
		
		// Out
		else {
			
			// 값 길이
			var len = getSize(val);

			// 값이 있는 경우 및 8글자, 10글자인 경우
			if(len > 0 && (len == 8 || len == 10)) {

				var a  = val.split("-");
				var y  = len == 8 ? val.substring(0, 4) : a[0];			// 년도
				var m  = Number(len == 8 ? val.substring(4, 6) : a[1]);	// 월
				var d  = Number(len == 8 ? val.substring(6, 8) : a[2]);	// 일
				var ld = getLastDay(y, m);								// 마지막날
				
				// 월, 일 유효한 경우에만 값 세팅
				if((m > 0 && m < 13) && (d > 0 && d <= ld)) {
					
					// 8글자
					if(len == 8) { target.val(y + "-" + addZero(m) + "-" + addZero(d)); }
				}
				
				// 유효하지 않은 경우
				else {

					target.val("");
					alert("유효하지 않은 날짜 형식입니다.");
					target.focus();
				}
			}
			
			// 그 외
			else {
				
				target.val("");
				alert("유효하지 않은 날짜 형식입니다.");
				target.focus();
			}
		}
	}
}

/**
 * 해당 년도, 해당 월 마지막날 계산
 * @param targetYear
 * @param targetMonth
 * @returns
 */
function getLastDay(targetYear, targetMonth) {
	
	// 마지막날짜 배열
	var monthsDay = [ 31, 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31 ];
	
	// 윤달계산
	if(((targetYear % 4 == 0) && (targetYear % 100 != 0)) || (targetYear % 400 == 0)) {
		
		monthsDay[1] = 29;
	}
	
	return monthsDay[targetMonth - 1];
}




/**
 * 날짜 세팅 함수
 * @param sdateId
 * @param edateId
 * @param dateMode : 1(오늘), 2(어제), 3(1주일), 4(한달), 5(내일), 6(모레), 7(3일전), 90(3개월전), 180(6개월전)
 */
function setDateBtn(sdateId, edateId, dateMode) {
	
	// 오늘 날짜
	var today = getDate(null);
	
	// 시작일자, 종료일자
	var sdate = "";
	var edate = "";
	
	// 오늘
	if(dateMode == 1) {
		
		sdate = today;
		edate = today;
	}
	
	// 어제
	else if(dateMode == 2) {
		
		sdate = getBeforeNextDate(today, -1);
		edate = today;
	}
	
	// 1주일
	else if(dateMode == 3) {
		
		sdate = getBeforeNextDate(today, -6);
		edate = today;
	}
	
	// 한 달
	else if(dateMode == 4) {
		
		sdate = getBeforeNextDate(today, -30);
		edate = today;
	}
	
	// 내일
	else if(dateMode == 5) {
		
		sdate = today;
		edate = getBeforeNextDate(today, 1);
	}
	
	// 모레
	else if(dateMode == 6) {
		
		sdate = today;
		edate = getBeforeNextDate(today, 2);
	}
	
	// 4일전
	else if(dateMode == 7) {
		
		sdate = getBeforeNextDate(today, -3);
		edate = today;
	}
	
	// 3일전
	else if(dateMode == 8) {
		
		sdate = getBeforeNextDate(today, -2);
		edate = today;
	}
		
	
	// 3개월전
	else if(dateMode == 90) {
		
		sdate = getBeforeNextDate(today, -91);
		edate = today;
	}
	
	// 6개월전
	else if(dateMode == 180) {
		
		sdate = getBeforeNextDate(today, -183);
		edate = today;
	}
	// 6개월후
	else if(dateMode == 180000) {
		
		sdate = getBeforeNextDate(today, -183);
		edate = getBeforeNextDate(today, 183);
	}	
	
	
	
	// 날짜값 세팅
	$("#" + sdateId).val(sdate);
	$("#" + edateId).val(edate);
}


/**
 * 사업자등록번호 유효성 체크 정규식
 * @param bizNo
 * @returns {Boolean}
 */
function checkBizNo(bizNo) { 
    // bizNo는 숫자만 10자리로 해서 문자열로 넘긴다. 
    var checkID = new Array(1, 3, 7, 1, 3, 7, 1, 3, 5, 1); 
    var tmpBizID, i, chkSum=0, c2, remander; 
    var result;
     
    bizNo = bizNo.replace(/-/gi,''); 
 
    for (i=0; i<=7; i++) {
        chkSum += checkID[i] * bizNo.charAt(i);
    } 
 
    c2 = "0" + (checkID[8] * bizNo.charAt(8)); 
    c2 = c2.substring(c2.length - 2, c2.length); 
    chkSum += Math.floor(c2.charAt(0)) + Math.floor(c2.charAt(1)); 
    remander = (10 - (chkSum % 10)) % 10 ; 
 
    if (Math.floor(bizNo.charAt(9)) == remander) {
        result = true ; // OK!
         
    } else {
        result = false;
         
    }
   
    return result; 
}




