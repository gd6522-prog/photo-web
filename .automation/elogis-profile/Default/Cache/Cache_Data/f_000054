		function IBSHEET01_OnClick(row, col, value, cellX, cellY, cellW, cellH){
			// IBSHEET01 마스터노선
			if(IBSHEET01.CellSaveName(row, col) == 'ROUTE_SEQ'){
				if(!IBSHEET01.GetCellValue(row, 'CENTER_CD')){
					alert("유효한 센터가 아닙니다.(센터코드에서 엔터키 또는 검색버튼)");
					IBSHEET01.SelectCell(row, 'CENTER_CD', {"Edit" : 1});
					return;
				}
				$.ajax({
					  type : 'POST'
					, url: '/tms/task/pm/TmsPmMastRouteStop/MstRouteCd/retrieve.do'
					, async: false
					, data: {
						center_grp_cd : IBSHEET01.GetCellValue(row, 'CENTER_CD'),
						deli_seq_cd : IBSHEET01.GetCellValue(row, 'DELI_SEQ_CD'), //$("#deli_seq_cd").val(),
						route_grp_cd : IBSHEET01.GetCellValue(row, 'ROUTE_GRP_CD') //$("#route_grp_cd").val()
					}
					, dataType: 'json'
						, success : function(result){
	      					if(result){
			      				if(result.VALUE.length == 0){
			      					IBSHEET01.InitCellProperty(row, col,{
										  'Type' : 'Combo'
										, 'ComboCode' :  result.VALUE
										, 'ComboText' :  result.TEXT
									})
			      				}
			      				else{
									IBSHEET01.InitCellProperty(row, col,{
										  'Type' : 'Combo'
										, 'ComboCode' : '|' + result.VALUE
										, 'ComboText' : '|' + result.TEXT
									})
		      				}
							IBSHEET01.SelectCell(row, 'ROUTE_SEQ', {"Edit" : 1});
						}
					}
				})
			}
		}

