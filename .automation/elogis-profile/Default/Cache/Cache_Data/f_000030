	  	if (Number(result.ALREADY_LEAVED_CNT) > 0){
	  		alert('배송시작(또는 실적확정)된 배송처가 포함되어 있습니다');
	  		doCallbackBlockScreen(false);
	  		return false;
	  	}
	  	else if (Number(result.CONFIRM_POINT_CNT) > 0){
	  		alert('확정된 배송처가 포함되어 있습니다');
	  		doCallbackBlockScreen(false);
	  		return false;
	  	}		    	  	
	  	else if (Number(result.SELECT_POINT_CNT) == 0){
	  		alert('노선을 조정할 대상이 선택되지 않았습니다');
	  		doCallbackBlockScreen(false);
	  		return false;
	  	}		    	  	
	  	else if (Number(result.MOBILE_ADJUST_CNT) > 0){
	  		alert('모바일에서 조정중인 배송처가 포함되어 있습니다');
	  		doCallbackBlockScreen(false);
	  		return false;
	  	}		    	  	
	  	else if (result.TARGET_ADJUST_STATUS == '2'){
	  		alert('모바일에서 조정중인 노선에 배송처를 추가할 수 없습니다.');
	  		doCallbackBlockScreen(false);
	  		return false;
	  	}
	  	else{		
	  		return true;
	  	}
	};	
	
  
