function getGridHiddenColumnIndexs(grid, exceptColumn) {
	var columns = grid.columns;//전체 컬럼
	var hiddenColumIndexs = [];//리턴 컬럼
	for (var c = 0; c < columns.length; c++) {
		if (columns[c].hidden && exceptColumn.indexOf(columns[c].dataIndex) < 0) {
			hiddenColumIndexs.push(columns[c].dataIndex);
		}
	}

	return hiddenColumIndexs;
}

