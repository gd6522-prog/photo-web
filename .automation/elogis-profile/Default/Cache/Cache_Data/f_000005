	/**
	 * 개인화 Column 정보로 grid.columnDefine을 refresh
	 * currentColumns : 개인화&현재그리드 columns 데이터
	 */
	setReColumnDefine: function(currentColumns) {
		var me = this;

		var rows = [];
		var group = null;
		var group = {};			//레벨별 메뉴 json
		var maxNODELEVEL = 0;	//최대레벨
		var orgColumn = null;	//실제 header column속성(orgColumn) - page coding source 상의 속성
		//column 레벨별로 분기
		Ext.Array.each(currentColumns, function(arr) {
			if (me.id == arr.GRID) {
				if (Util.isNull(group[arr.NODELEVEL])) group[arr.NODELEVEL] = [];
				// 2022-10-30 / sjh / modify / 개인화 후 소스상의 컬럼이 삭제 된 경우 columnDefine 생성 대상에서 제외,
				// 그리드개인화 저장가능한 상태로 변경
				var bol = true;
				if (!findColumnDefine(me.orgColumnDefine, arr)) {
					me.columnschange = true;
				} else {
					group[arr.NODELEVEL].push(Ext.clone(arr));
				}
				maxNODELEVEL = (maxNODELEVEL > arr.NODELEVEL ? maxNODELEVEL : arr.NODELEVEL);
			}
		});
		//excel header 생성용.
		me.columnGroupDepth = maxNODELEVEL;

		//개인화가 있을 경우만 실행
		if (!Util.isNull(group[1])) {
			//최하위 레벨인 경우 다음 for문에 실제 header column속성(orgColumn)을 읽을 수 없으므로 orgColumn를 먼저 생성한다.
			for (var k = 0; k < group[maxNODELEVEL].length; k++) {
				//실제 header column속성(orgColumn)에 개인화 속성으로 변경
				orgColumn = me.findColumnConfig(me.columnDefine, group[maxNODELEVEL][k]);
				//민대리 2017-06-29
				try {
					//if문 주석처리가 되어있었음. - 이유 확인 필요.
					//if문이 없는 경우 - 그리드 헤더 lock/unlock 시 orgColumn 이 null 이라 오류 발생.
					if (orgColumn != null) {
						orgColumn.hidden = (group[maxNODELEVEL][k].HIDDEN == "Y" ? true : false);
						orgColumn.hideable = (group[maxNODELEVEL][k].HIDEABLE == "Y" ? true : false);
					}
				} catch (e) { console.log(e); }
				group[maxNODELEVEL][k].orgColumn = orgColumn;
			}

			//레벨별 header column을 각 부모 column에 삽입한다.
			for (var i = maxNODELEVEL; i > 1; i--) {
				//각 레벨 column 정보
				for (var k = 0; k < group[i].length; k++) {
					//부모레벨에 자식레벨정보 삽입
					var pIdx = i - 1;				//부모레벨
					for (var j = 0; j < group[pIdx].length; j++) {
						//실제 header column속성(orgColumn)을 가져온다.
						if (Util.isNull(group[pIdx][j].orgColumn)) {
							//실제 header column속성(orgColumn)에 개인화 속성으로 변경
							orgColumn = me.findColumnConfig(me.columnDefine, group[pIdx][j]);
							if (Util.isNull(orgColumn)) continue;

							orgColumn.hidden = (group[pIdx][j].HIDDEN == "Y" ? true : false);
							orgColumn.hideable = (group[pIdx][j].HIDEABLE == "Y" ? true : false);
							group[pIdx][j].orgColumn = orgColumn;
						}

						//부모column일 경우 삽입
						if (group[pIdx][j].NAME == group[i][k].PARENT) {
							if (Util.isNull(group[pIdx][j].orgColumn.columns)) group[pIdx][j].orgColumn.columns = [];
							group[pIdx][j].orgColumn.columns.push(group[i][k].orgColumn);
						}
					}
				}
			}
			//실제 header column속성(orgColumn)
			for (var k = 0; k < group[1].length; k++) {
				rows.push(group[1][k].orgColumn);
			}
		}
		if (rows.length > 0) me.columnDefine = rows;
	},
	/**
	 * 개인화 Column 정보로 실제 Page Source Column정보 찾기. private
	 * config : 검색할 Column 정보
	 * userCol : 개인화 Column 정보
	 */
	findColumnConfig: function(config, userCol) {
		var me = this;
		var curentColumn = null;

		Ext.Array.each(config, function(col) {
			//민대리 2017-06-29 컴포넌트 생성 시점과 헤더메뉴바 이벤트 시점의 스코프가 달라서 해당 인자를 참조하지 못하기 때문 (사이드이펙트 우려됨)
			if (col) {
				top.Ext.getCmp('main-mainContainer').getActiveTab().col = col;
			} else {
				col = top.Ext.getCmp('main-mainContainer').getActiveTab().col;
			}
			//header group 중 최화위 column으로 하위 columns정보가 없을 경우 이름이 같으면 동일 데이터로 판단
			if (userCol.LASTYN == "Y" && Util.isNull(col.columns)) {
				//정보일치
				if (Util.nvl(col.colName, col.header) == userCol.NAME) {
					curentColumn = col;
					return false;
				} else {
					//NO인경우 이름이 없으므로 별도처리
					if (userCol.NAME == 'NO' && col.type == 'gridrownumber') {
						curentColumn = col;
						return false;
					}
					if (userCol.NAME == 'ROW_DELETE') {
						curentColumn = { header: 'ROW_DELETE' };
						return false;
					}
					if (userCol.NAME == 'ROW_STATUS_TXT') {
						curentColumn = { header: 'ROW_STATUS_TXT' };
						return false;
					}
					if (userCol.NAME == 'ROW_STATUS') {
						curentColumn = { header: 'ROW_STATUS' };
						return false;
					}
				}
				//header group 중 하위 columns정보가 있을 경우
			} else {
				//최하위 column이 아닌 경우 header속성(이름)밖에 존재하지 않으므로 이름이 같으면 columns속성 제거하여 리턴
				if (userCol.LASTYN == "N" && Util.nvl(col.colName, col.header) == userCol.NAME) {
					curentColumn = Ext.clone(col);
					delete curentColumn.columns;
					return false;
				} else {
					//하위 columns속성 존재시 columns속성에서 데이터 찾기
					col = me.findColumnConfig(col.columns, userCol);
					if (!Util.isNull(col)) {
						curentColumn = col;
						return false;
					}
				}
			}
		});
		return curentColumn;
	},
	/**
	 * column validation create
	 */
	setValidator: function(gridColumns) {
		var me = this;
		if (gridColumns.editor && Util.nvl(gridColumns.required, false)) {
			if (!me.validator) {
				me.validator = {};
			}
			if (!me.validator[gridColumns.dataIndex]) {
				me.validator[gridColumns.dataIndex] = [];
			}
			me.validator[gridColumns.dataIndex].unshift(function(grid, record, headerName, value) {
				var retVal = true;
				if (Util.isNull(value)) retVal = Lang.getRep('MSG_REQUIRED_FIELD_REP', [headerName]);
				return retVal;
			});
		}
		if (gridColumns.editor && me.validator && me.validator[gridColumns.dataIndex]) {
			gridColumns.editor.headerName = gridColumns.header;
			gridColumns.editor.validCheckFunctions = me.validator[gridColumns.dataIndex];
			gridColumns.editor.validator = function(value) {
				var editInfo = Ext.getCmp(me.id).currentEditingInfo;
				var retVal = true;
				if (this.validCheckFunctions) {
					for (var n = 0; n < this.validCheckFunctions.length; n++) {
						retVal = this.validCheckFunctions[n](editInfo.grid, editInfo.record, this.headerName, value);
						if (retVal !== true) break;
					}
				}
				return retVal;
			};
		}
		return gridColumns;
	},
	/**
