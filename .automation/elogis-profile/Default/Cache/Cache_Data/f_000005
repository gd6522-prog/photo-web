 *				subKey : child객체 변수명(존재시 재귀호출 하위에서 key를 계속 검색)
 *           }
 * changeVal : 검색결과객체와 치환 될 객체
 */
function findObject(columns, find, changeVal) {
	if (Ext.isArray(columns)) {
		for (var i = 0; i < columns.length; i++) {
			if (columns[i][find.key] == find.value) {
				//종선
				//	if(columns[i] != null && columns[i][find.key]==find.value){
				//				console.log(columns[i][find.key]);
				//				console.log(columns[i]);
				//				console.log(find.value);
				//				console.log(changeVal);
				changeVal.hidden = columns[i].hidden;
				changeVal.hideable = columns[i].hideable;
				columns[i] = changeVal;

				break;
			}
			if (!Util.isNull(columns[i][find.subKey])) {
				//종선
				//if(columns[i] != null && !Util.isNull(columns[i][find.subKey])){
				columns[i][find.subKey] = findObject(columns[i][find.subKey], find, changeVal);
			}
		};
	}
	return columns;
}

/**
 * [그리드개인화]
 * Grid 개인화 저장후 소스상 추가되는 Column을 Grid생성시 반영
 * 추가 Column은 최하위 레벨만 추가되며 마지막 Column뒤에 추가된다.
 * grid : 대상 Grid
 * config : 소스상의 컬럼속성
 */
function setDifferenceColumn(grid, config) {
	for (var i = 0; i < config.length; i++) {
		if (Util.isNull(config[i].columns)) {
			addColumnDefine(grid, grid.columnDefine, config[i]);
		} else {
			setDifferenceColumn(grid, config[i].columns);
		}
	}
}

/**
 * [그리드개인화]
 * Grid 개인화 저장후 소스상 추가되는 Column을 Grid생성시 반영
 * 추가 Column은 최하위 레벨만 추가되며 마지막 Column뒤에 추가된다.
 * grid : 대상 Grid
 * columns : 검색할 array객체
 * find    : 비교할 객체
 */
function addColumnDefine(grid, columns, cCol) {
	//찾는대상의 명 없을 경우 생성
	if (Util.isNull(cCol.NAME))
		cCol.NAME = Util.nvl(cCol.colName, cCol.header);

	//NO인경우 이름이 없으므로 별도처리
	if (Util.isNull(cCol.NAME))
		return false;
	if (cCol.NAME == 'NO' && cCol.type == 'gridrownumber')
		return false;
	if (cCol.NAME == 'ROW_DELETE')
		return false;
	if (cCol.NAME == 'ROW_STATUS_TXT')
		return false;
	if (cCol.NAME == 'ROW_STATUS')
		return false;

	var rtnVal = findColumnDefine(columns, cCol);
	if (!rtnVal) {
		grid.columnDefine.push(cCol);
		grid.columnschange = true;
	}
}

/**
 * [그리드개인화]
 * Grid 개인화시 페이지에서 설정되지 않고 자동으로 추가되는 Column을 찾아 리턴
 * 모든 Json 객체에서 찾을 수 있게 만들려고 했으나 옵션이 너무 많이 추가되야해서 일단 보류.
 * 일반orTree Grid 모두 동일하게 사용하므로 일반 function으로 생성함.
 * columns : 검색할 array객체
 * find    : 비교할 객체
 */
function findColumnDefine(columns, find) {
	if (Ext.isArray(columns)) {
		for (var i = 0; i < columns.length; i++) {
			columns[i].NAME = Util.nvl(columns[i].colName, columns[i].header);
			if (columns[i].type == "gridrownumber" && find.NAME == "NO") {
				return columns[i];
			}
			if (columns[i].NAME == find.NAME) {
				return columns[i];
			}
			if (!Util.isNull(columns[i].columns)) {
				var rtnVal = findColumnDefine(columns[i].columns, find);
				if (rtnVal)
					return rtnVal;
			}
		};
	}
	return false;
}

/**
 * ajax
 * 그리드 조회 외 사용시
 */
function ajaxCallback(target, url, param, callbackFunc, failCallbackFunc, async) {
	var mask = null;
	
	
	if (!Util.isNull(target)) {
		//차트 화면의 경우 버튼 중복으로 눌리는 현상 수정
		mask = new Ext.LoadMask({ msg: "Loading...", target: target });
		mask.show();
	}
	if (async == null) {
		async = true;
	}

	param = Util.nvl(param, {});
	if (Util.isNull(param.CURRENT_MENUCODE)) param.CURRENT_MENUCODE = CURRENT_MENUCODE;

	var jsonData = DS_SEARCHCONDITION;

	Ext.Ajax.request({
		url: url,
		jsonData: jsonData,
		params: param,
		async: async,
		callback: function(options, success, response) {
			var json = Ext.decode(response.responseText);
			if (!Util.isNull(mask)) mask.destroy();
			if (json["ErrorMsg"] === "OK") {
				//target Store 없을 경우 자동생성
				if (!Util.isNull(target) && !Util.isNull(target.store) && target.store.storeId == "ext-empty-store" && Ext.isFunction(target.setStore) && !Util.isNull(json["DS_OUT"]) && json["DS_OUT"].length > 0) {
					var fields = []
						, obj = json["DS_OUT"][0];
					for (var key in obj) {
						fields.push(obj[key])
					}
					target.setStore(Ext.create('Ext.data.Store', {
						fields: fields
					}));
				}
				if (callbackFunc) callbackFunc(target, json["DS_OUT"], json);
			}
			else {
				if (failCallbackFunc) {
					failCallbackFunc(target, json);
				} else {
					Ext.MessageBox.show({
						title: (Util.isNull(target.title) ? '' : Lang.get(target.title)),
						msg: json["ErrorMsg"],
						buttons: Ext.MessageBox.OK,
						icon: Ext.MessageBox.ERROR,
						//임시
						fn: function(btn) {
							if (btn == 'ok') {
								//세션타임아웃시 로그인화면으로 이동하도록 refresh
								if (json["ErrorCode"] == "SESSION_TIMEOUT") {
									top.location.reload();
								}
							}
						}
					});
				}
			}
		}
	});
}


