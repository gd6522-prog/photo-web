					//2017-10-24 이병옥추가  (extjs 6.0.1에서 6.5.2로 업그레이드 후 오류 발생하여 위의 내용 대체)
					grid.mask("Please wait...");

					var encodeParams = {}		//paging시 encodeURIComponent를 여러번 반복하여 타게되므로 encodeParams를 별개로 생성
