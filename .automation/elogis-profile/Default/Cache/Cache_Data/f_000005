		commonEncode: function(password) {
			var pwType = ClientData.getSysConfig("PASSWORD_ENCRYPT_TYPE");
			if (pwType == "B") {
				return VC.util.Base64.encode(password);
			} else if (pwType == "S") {
				return VC.util.SHA256.encode(password);
			} else {
				return password;
			}
