	/**
	 * 엑셀 업로드 - 그리드 데이터 로딩
	 * 업로드 이후 리턴받은 json을 그리드에 로드(업로드 성공 후 호출됨)
	 */
	, excelLoadData: function(data) {
		//console.log("excelLoadData in cm");
		var me = this;

		var param = {};

		//commonExcelGetGridInfo(param, me);
		me.getColumnInfoForExcelDown(param);

		var colNameArr = param.EXCEL_COLNAMES.split(",");
		var headerColArr = param.EXCEL_HEADERCOLS.split(",");

		var EXCEL_CHECK_COLS = "," + param.EXCEL_COL_CHECKCOLS + ",";
		var EXCEL_COMBO_COLS = "," + param.EXCEL_COL_COMBOCOLS + ",";
		var EXCEL_DATE_COLS = "," + param.EXCEL_DATE_COLS + ",";

		var finalData = [];
		var result_row;
		var value;
		for (var i = 0; i < data.length; i++) {
			result_row = {
				ROW_STATUS: 'I',
				ROW_STATUS_TXT: Lang.get('INSERT')
			};

			for (var j = 0; j < colNameArr.length; j++) {
				value = Util.nvl(data[i][Lang.get(headerColArr[j])], "").trim();

				if (EXCEL_CHECK_COLS.indexOf("," + colNameArr[j] + ",") > -1) {
					value = value == 'Y' ? true : false;
				} else if (EXCEL_COMBO_COLS.indexOf("," + colNameArr[j] + ",") > -1) {
					me.comboColumnStore[colNameArr[j]].each(function(record) {
						if (record.data.NAME == value) {
							value = record.data.CODE;
							return;
						}
					});
				} else if (EXCEL_DATE_COLS.indexOf("," + colNameArr[j] + ",") > -1) {
					value = Ext.Date.parse(value, me.dateColumnsRenderFormat[colNameArr[j]] || "") || Ext.Date.parse(value, me.dateColumnsDateFormat[colNameArr[j]] || "");
				}

				result_row[colNameArr[j]] = value;
			}
			finalData.push(result_row);
		}
		me.loadData(Util.nvl(viewPort, me), finalData);
	}

