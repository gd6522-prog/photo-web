		/**
		 * 2022.03.15 / sjh
		 * 전화번호를 asterisk로 masking. - 조회시 개인정보는 보여주지 않기 위해 보안상조치
		 * str : masking할 값
		 * 전화번호 또는 휴대전화번호 중간 4자리
		 * ex : 02-****-3853 / 010-****-8535
		 */
		telToAsterisk: function(str) {
			if (Util.isNull(str)) {
				return;
			}
			str = str.replace(/[^0-9]/g, '');
			var tmp = '';
			if (str.length < 4) {
				return str;
			} else if (str.substring(0, 2) == '02') {

				if (str.length < 6) {
					tmp += str.substr(0, 2);
					tmp += '-';
					tmp += str.substr(2);
					return tmp;
				} else if (str.length < 10) {
					tmp += str.substr(0, 2);
					tmp += '-';
					tmp += '****';
					tmp += '-';
					tmp += str.substr(5);
					return tmp;
				} else {
					tmp += str.substr(0, 2);
					tmp += '-';
					tmp += '****';
					tmp += '-';
					tmp += str.substr(6);
					return tmp;
				}

			} else if (str.length < 7) {
				tmp += str.substr(0, 3);
				tmp += '-';
				tmp += str.substr(3);
				return tmp;
			} else if (str.length < 11) {
				tmp += str.substr(0, 3);
				tmp += '-';
				tmp += '****';
				tmp += '-';
				tmp += str.substr(6);
				return tmp;
			} else {
				tmp += str.substr(0, 3);
				tmp += '-';
				tmp += '****';
				tmp += '-';
				tmp += str.substr(7);
				return tmp;
			}
		},

