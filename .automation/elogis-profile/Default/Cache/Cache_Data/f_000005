/**
 * 권한 적용
 * @param DS_USER_MENU_AUTH
 */
function __applyAuth__(menuAuth) {

	DS_USER_MENU_AUTH = menuAuth;
	if (DS_USER_MENU_AUTH.length < 1) return;
	userAuths = [];
	Ext.Array.forEach(DS_USER_MENU_AUTH, function(item, index, allItems) {
		userAuths.push(item.ROLECODE);
	});
	cmpToApplyAuth = Ext.ComponentQuery.query('[authType]');
	var hideDBtn = false;
	var hideSaveBtn = false;
	Ext.Array.forEach(cmpToApplyAuth, function(item, index, allItems) {

		//if(!Util.isNull(item.up('grid'))) hideDBtn = Util.nvl(item.up('grid').hideDBtn, false);
		//if(!Util.isNull(item.up('grid'))) hideSaveBtn = Util.nvl(item.up('grid').hideSaveBtn, false);

		if (!Util.isNull(item.up('form'))) {

			hideDBtn = Util.nvl(Ext.getCmp(item.up('form').id.replace('EditForm', '')).popEditWinConfig.hideDBtn, false);

			//신규등록일경우 삭제 버튼 hidden
			if (Ext.getCmp(item.up('form').id.replace('EditForm', '')).editForm.recodestatus == 'I') {
				hideDBtn = true;
			}

		}

		if (!Util.isNull(item.up('form'))) hideSaveBtn = Util.nvl(Ext.getCmp(item.up('form').id.replace('EditForm', '')).popEditWinConfig.hideSaveBtn, false);

		if (Ext.Array.contains(userAuths, item.authType)) {

			if (item.authType == 'IUD' && item.iconCls == 'icon-save' && hideSaveBtn) item.hide();
			else if (item.authType == 'IUD' && item.iconCls == 'icon-del' && hideDBtn) item.hide();
			else item.show()


		} else {
			item.hide();
		}
	});
}

