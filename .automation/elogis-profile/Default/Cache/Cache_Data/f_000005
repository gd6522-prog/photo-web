		/**
		 * byte수 얻기(db에 따른 한글 byte 수를 정한다.)
		 *
		 *
				1. KO16KSC5601
					- 한글 지원상태 : 한글 2350자
					- 지원버전 : 7.x
					- 한글바이트 : 2바이트
				2. KO16MSWIN949
					- 한글 지원상태 : KO16KSC5601 + 확장 ( 총 11172자 )
					- 지원버전 : 8.0.6 이상
					- 한글바이트 : 2바이트
				3. UTF8
					- 한글 지원상태 : 한글 11172자
					- 지원버전 : 8.0 이후
					- 한글바이트 : 3바이트
				4. AL32UTF8
					- 한글 지원상태 : 한글 11172자
					- 지원버전 : 9i Release 1 이상
					- 한글바이트 : 3바이트

		 */
		getByte: function(value) {

			//4바이트 체크아 않되서 주석 처리함.
			//	for(b=i=0  ;  c = value.charCodeAt(i++)  ;  b+=c>>11?3:c>>7?2:1);
			//	return b;

			var str_len = value.length;
			var rbyte = 0;
			var one_char = "";

			for (var i = 0; i < str_len; i++) {

				/* 베트남어는 1~3Byte를 사용하기 때문에 고정 3Byte인 한글과 다름(김민수, 2017-05-24) */
				try {
					one_char = encodeURI(value.charAt(i));
				} catch (e) {
					one_char = encodeURI(value.substr(i, 2));
					i++;
				}

				if (one_char.indexOf('%') < 0) {
					//URI에서 사용되는 영문/숫자/특수문자인 경우 1Byte
					rbyte++;											//영문 등 나머지 1Byte
				} else {
					//UNICODE인 경우 '%'의 개수로 Byte 개산
					var bytes = one_char.split('%');
					rbyte += bytes.length - 1;
				}
			}
			//console.log(''+rbyte );
			return rbyte;
		},
		
        /**
         * 최대 바이트수 만큼 문자열 제거
         1. value : 문자열
         2. byte : 자를 문자열 바이트 수
         3. return 자른 문자열  */
        getByteCut: function (value, byte) {
            var str_len = value.length;
            var rbyte = 0;
            var one_char = '';
            var fullStr = '';
            
            for (var i = 0; i < str_len; i++) {
                try {
                    one_char = encodeURI(value.charAt(i));
                    fullStr = fullStr + value.charAt(i);
                } catch (e) {
                    one_char = encodeURI(value.substr(i, 2));
                    i++;
                }
                
                if (one_char.indexOf('%') < 0) {
                    //URI에서 사용되는 영문/숫자/특수문자인 경우 1Byte
                    rbyte++;                                            //영문 등 나머지 1Byte
                } else {
                    //UNICODE인 경우 '%'의 개수로 Byte 개산
                    var bytes = one_char.split('%');
                    rbyte += bytes.length - 1;
                }
                if (rbyte == byte) {
                    break;
                } else if (rbyte > byte) {
                    fullStr = fullStr.substring(0, fullStr.length - 1);
                    break;
                }
            }
            return fullStr;
        },
        
