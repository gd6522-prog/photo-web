		return params;
	}
});
/********************************************************************************************************
 *Ajax request받을때 aborted, timedout일 경우  공통적으로 메시지창 처리
 ********************************************************************************************************/
Ext.override(Ext.data.request.Base, {
	privates: {
		/**
		 * Creates the exception object
		 * @param {Object} request
		 * @private
		 */
		createException: function() {
			var me = this,
				result;
			result = {
				request: me,
				requestId: me.id,
				status: me.aborted ? -1 : 0,
				statusText: me.aborted ? 'transaction aborted' : 'communication failure',
				getResponseHeader: me._getHeader,
				getAllResponseHeaders: me._getHeaders
			};
			if (me.aborted) {
				result.aborted = true;
			}
			if (me.timedout) {
				result.timedout = true;
			}
			if (result.aborted) {
				Ext.MessageBox.show({
					//title: (Util.isNull(me.titleText) ? '' : Lang.get(me.titleText)),
					msg: result.statusText,
					buttons: Ext.MessageBox.OK,
					icon: Ext.MessageBox.WARRING
				});
			}
			if (result.timedout) {
				Ext.MessageBox.show({
					//title: (Util.isNull(me.titleText) ? '' : Lang.get(me.titleText)),
					msg: "REQUEST_TIMEOVER",//서버 대기시간 초과로 결과를 알 수 없습니다.<br>잠시 후 결과를 확인하시거나 관리자에게 문의주세요.
					buttons: Ext.MessageBox.OK,
					icon: Ext.MessageBox.WARRING
				});
			}
			return result;
		},
		_getHeader: function(name) {
			var headers = this.headers;
			return headers && headers[name.toLowerCase()];
		},
		_getHeaders: function() {
			return this.headers;
		}
	}
});

