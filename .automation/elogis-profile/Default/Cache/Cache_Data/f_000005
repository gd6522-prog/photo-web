				mainContainer.fireRemoveEvent = false;
				mainContainer.fireTabChangeEvent = false;

				var currentTab = mainContainer.getActiveTab();
				var idxToAdd = mainContainer.items.indexOf(currentTab);

				var tabIframe = Ext.getDom(currentTab.id + "_iframe");

				if (tabIframe) {
					tabIframe.contentWindow.location = "about:blank";
				}
				mainContainer.remove(currentTab);
				mainContainer.fireRemoveEvent = true;

				var params = {
					MENUCODE: menuCode,
					MENUPATH: encodeURIComponent(menuFullPath),
					APP: app,
					KEYWORD_INDEX: keywordIndex,
					KEYWORD: keyword
				};

				var addedTab = mainContainer.insert(idxToAdd, {
					title: menuName,
					id: newTabId,
					menuCode: menuCode,
					menuLang: menuLang,
					app: app,
					iconCls: 'icon-tab-' + app,
