	/**
	 * 헤더 상세 설정. private
	 */
	setGridColumn: function(gridColumn, col, modelField) {
		var me = this;
		//기본 값
		if (col.defaultValue) {
			modelField.defaultValue = col.defaultValue;
		}

		//int 나 float 타입
		if (col.type == 'int' || col.type == 'float' || col.type == 'number') {
			modelField.type = col.type;

			col.align = 'right';
			gridColumn.align = 'right';
			gridColumn.xtype = 'numbercolumn';
			if (col.format) {
				gridColumn.format = col.format;
			} else {
				gridColumn.format = col.type == 'int' ? ClientData.getFormat('INT_FORMAT') : ClientData.getFormat('FLOAT_FORMAT');
			}
			if (Util.nvl(me.editable, true) && Util.nvl(col.editable, true)) {
				//SKU 단위별 소수점 처리가 아닌 경우 구분하여 처리(2017-10-20. 이강규)
				if (!Util.isNull(col.refField)) {
					gridColumn.editor = {
						xtype: 'numberfield',
						refField: col.refField,
						refFieldInt: col.refFieldInt,
						refFieldFloat: col.refFieldFloat,
						listeners: {
							afterRender: function() {
								var me = this;
								this.ownerCt.addListener('beforestartedit', function(editor) {
									if (editor.context.record.get(me.refField) == me.refFieldInt) {
										me.maskRe = /[0123456789\-]/
									} else if (editor.context.record.get(me.refField) == me.refFieldFloat) {
										me.maskRe = /[0123456789\.e\+\-]/
									}
								});
								this.ownerCt.addListener('beforecomplete', function(editor) {
									if (editor.context.record.get(me.refField) == me.refFieldInt) {
										me.setValue(Math.floor(me.getValue()));
									}
								});
							}
						}
					}
