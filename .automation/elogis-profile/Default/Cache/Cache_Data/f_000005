	initComponent: function() {
		var me = this;
		if (!me.disabled && !me.readOnly && !Ext.isIE && !me.column && me.xtype != "textarea" && me.xtype != "textareafield") {
			//민대리 2017-06-30
			if (!me.findPlugin('clearbutton')) {
