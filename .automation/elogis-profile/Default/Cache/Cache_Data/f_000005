/**
 * Ext.TaskManager inteval 반복호출시 메뉴탭 활성시만 호출하도록한다.
 * Ext.TaskManager 호출함수 상단에 호출하도록한다.
 *
 *	task = Ext.TaskManager.start({
 *		run: callFunction,
 *		interval: 1000
 *	});
 *
 *  function callFunction(){
 *		activeTaskManager(task)
 *  }
 */
function activeTaskManager(task) {
	var activeTab = top.Ext.getCmp('main-mainContainer').getActiveTab();

	activeTab.addListener('show', function() {
		if (!Util.isNull(task)) Ext.TaskManager.start(task);
	});
	activeTab.addListener('hide', function() {
		if (!Util.isNull(task)) Ext.TaskManager.stop(task);
	});
}



