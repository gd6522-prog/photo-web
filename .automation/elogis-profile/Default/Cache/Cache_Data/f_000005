	statics: {
		encode: function(text) {

			if (/([^\u0000-\u00ff])/.test(text)) {
				throw new Error("Can't base64 encode non-ASCII characters.");
			}

			var digits = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/",
				i = 0,
				cur, prev, byteNum,
				result = [];

			while (i < text.length) {

				cur = text.charCodeAt(i);
				byteNum = i % 3;

				switch (byteNum) {
					case 0: //first byte
						result.push(digits.charAt(cur >> 2));
						break;

					case 1: //second byte
						result.push(digits.charAt((prev & 3) << 4 | (cur >> 4)));
						break;

					case 2: //third byte
						result.push(digits.charAt((prev & 0x0f) << 2 | (cur >> 6)));
						result.push(digits.charAt(cur & 0x3f));
						break;
				}

				prev = cur;
				i++;
			}

			if (byteNum == 0) {
				result.push(digits.charAt((prev & 3) << 4));
				result.push("==");
			} else if (byteNum == 1) {
				result.push(digits.charAt((prev & 0x0f) << 2));
				result.push("=");
			}

			return result.join("");
		},
		decode: function(text) {

			text = text.replace(/\s/g, "");

			if (!(/^[a-z0-9\+\/\s]+\={0,2}$/i.test(text)) || text.length % 4 > 0) {
				throw new Error("Not a base64-encoded string.");
			}

			//local variables
			var digits = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/",
				cur, prev, digitNum,
				i = 0,
				result = [];

			text = text.replace(/=/g, "");

			while (i < text.length) {

				cur = digits.indexOf(text.charAt(i));
				digitNum = i % 4;

				switch (digitNum) {

					//case 0: first digit - do nothing, not enough info to work with

					case 1: //second digit
						result.push(String.fromCharCode(prev << 2 | cur >> 4));
						break;

					case 2: //third digit
						result.push(String.fromCharCode((prev & 0x0f) << 4 | cur >> 2));
						break;

					case 3: //fourth digit
						result.push(String.fromCharCode((prev & 3) << 6 | cur));
						break;
				}

				prev = cur;
				i++;
			}

			return result.join("");
		}
	}
});

/********************************************************************************************************
 * SHA256
 ********************************************************************************************************/
Ext.define('VC.util.SHA256', {
	statics: {
		encode: function(s) {

			var chrsz = 8;
			var hexcase = 0;

			function safe_add(x, y) {
				var lsw = (x & 0xFFFF) + (y & 0xFFFF);
				var msw = (x >> 16) + (y >> 16) + (lsw >> 16);
				return (msw << 16) | (lsw & 0xFFFF);
			}

			function S(X, n) { return (X >>> n) | (X << (32 - n)); }
			function R(X, n) { return (X >>> n); }
			function Ch(x, y, z) { return ((x & y) ^ ((~x) & z)); }
			function Maj(x, y, z) { return ((x & y) ^ (x & z) ^ (y & z)); }
			function Sigma0256(x) { return (S(x, 2) ^ S(x, 13) ^ S(x, 22)); }
			function Sigma1256(x) { return (S(x, 6) ^ S(x, 11) ^ S(x, 25)); }
			function Gamma0256(x) { return (S(x, 7) ^ S(x, 18) ^ R(x, 3)); }
			function Gamma1256(x) { return (S(x, 17) ^ S(x, 19) ^ R(x, 10)); }

			function core_sha256(m, l) {

				var K = new Array(0x428A2F98, 0x71374491, 0xB5C0FBCF, 0xE9B5DBA5, 0x3956C25B, 0x59F111F1,
					0x923F82A4, 0xAB1C5ED5, 0xD807AA98, 0x12835B01, 0x243185BE, 0x550C7DC3,
					0x72BE5D74, 0x80DEB1FE, 0x9BDC06A7, 0xC19BF174, 0xE49B69C1, 0xEFBE4786,
					0xFC19DC6, 0x240CA1CC, 0x2DE92C6F, 0x4A7484AA, 0x5CB0A9DC, 0x76F988DA,
					0x983E5152, 0xA831C66D, 0xB00327C8, 0xBF597FC7, 0xC6E00BF3, 0xD5A79147,
					0x6CA6351, 0x14292967, 0x27B70A85, 0x2E1B2138, 0x4D2C6DFC, 0x53380D13,
					0x650A7354, 0x766A0ABB, 0x81C2C92E, 0x92722C85, 0xA2BFE8A1, 0xA81A664B,
					0xC24B8B70, 0xC76C51A3, 0xD192E819, 0xD6990624, 0xF40E3585, 0x106AA070,
					0x19A4C116, 0x1E376C08, 0x2748774C, 0x34B0BCB5, 0x391C0CB3, 0x4ED8AA4A,
					0x5B9CCA4F, 0x682E6FF3, 0x748F82EE, 0x78A5636F, 0x84C87814, 0x8CC70208,
					0x90BEFFFA, 0xA4506CEB, 0xBEF9A3F7, 0xC67178F2);

				var HASH = new Array(0x6A09E667, 0xBB67AE85, 0x3C6EF372, 0xA54FF53A, 0x510E527F, 0x9B05688C, 0x1F83D9AB, 0x5BE0CD19);

				var W = new Array(64);
				var a, b, c, d, e, f, g, h, i, j;
				var T1, T2;

				m[l >> 5] |= 0x80 << (24 - l % 32);
				m[((l + 64 >> 9) << 4) + 15] = l;

				for (var i = 0; i < m.length; i += 16) {
					a = HASH[0];
					b = HASH[1];
					c = HASH[2];
					d = HASH[3];
					e = HASH[4];
					f = HASH[5];
					g = HASH[6];
					h = HASH[7];

					for (var j = 0; j < 64; j++) {
						if (j < 16) W[j] = m[j + i];
						else W[j] = safe_add(safe_add(safe_add(Gamma1256(W[j - 2]), W[j - 7]), Gamma0256(W[j - 15])), W[j - 16]);

						T1 = safe_add(safe_add(safe_add(safe_add(h, Sigma1256(e)), Ch(e, f, g)), K[j]), W[j]);
						T2 = safe_add(Sigma0256(a), Maj(a, b, c));

						h = g;
						g = f;
						f = e;
						e = safe_add(d, T1);
						d = c;
						c = b;
						b = a;
						a = safe_add(T1, T2);
					}

					HASH[0] = safe_add(a, HASH[0]);
					HASH[1] = safe_add(b, HASH[1]);
					HASH[2] = safe_add(c, HASH[2]);
					HASH[3] = safe_add(d, HASH[3]);
					HASH[4] = safe_add(e, HASH[4]);
					HASH[5] = safe_add(f, HASH[5]);
					HASH[6] = safe_add(g, HASH[6]);
					HASH[7] = safe_add(h, HASH[7]);
				}
				return HASH;
			}

			function str2binb(str) {
				var bin = Array();
				var mask = (1 << chrsz) - 1;
				for (var i = 0; i < str.length * chrsz; i += chrsz) {
					bin[i >> 5] |= (str.charCodeAt(i / chrsz) & mask) << (24 - i % 32);
				}
				return bin;
			}

			function Utf8Encode(string) {
				string = string.replace(/\r\n/g, "\n");
				var utftext = "";

				for (var n = 0; n < string.length; n++) {

					var c = string.charCodeAt(n);

					if (c < 128) {
						utftext += String.fromCharCode(c);
					}
					else if ((c > 127) && (c < 2048)) {
						utftext += String.fromCharCode((c >> 6) | 192);
						utftext += String.fromCharCode((c & 63) | 128);
					}
					else {
						utftext += String.fromCharCode((c >> 12) | 224);
						utftext += String.fromCharCode(((c >> 6) & 63) | 128);
						utftext += String.fromCharCode((c & 63) | 128);
					}

				}

				return utftext;
			}

			function binb2hex(binarray) {
				var hex_tab = hexcase ? "0123456789ABCDEF" : "0123456789abcdef";
				var str = "";
				for (var i = 0; i < binarray.length * 4; i++) {
					str += hex_tab.charAt((binarray[i >> 2] >> ((3 - i % 4) * 8 + 4)) & 0xF) +
						hex_tab.charAt((binarray[i >> 2] >> ((3 - i % 4) * 8)) & 0xF);
				}
				return str;
			}

			s = Utf8Encode(s);
			return binb2hex(core_sha256(str2binb(s), s.length * chrsz));
		}
	}
});

/********************************************************************************************************
 * Ext time은 날짜형식으로 데이터가 움직이므로 문자열 기반으로 만듬.
 ********************************************************************************************************/
Ext.define('VC.components.Time', {
	extend: 'Ext.form.field.Spinner',
	alias: 'widget.vtimefield',
	enableKeyEvents: true,	//key event 활성화
	minValue: 0,
	maxValue: 2359,
	formatter: ':',		//시간 splitter
	step: 1,
	initComponent: function() {
		var me = this
			, regexStr;
		me.listeners = me.listeners || {};
		//focus시 edit format
		me.listeners.focus = function(comp, e, eOpts) {
			comp.setValue(comp.getValue())
		}
		me.listeners.keypress = function(comp, e, eOpts) {
			//숫자만 입력가능
			if (e.keyCode < 47 || e.keyCode > 57) {
				e.preventDefault();
			}
		}
		//입력형식 체크
		regexStr = "([0-9]){2}\\" + me.formatter + "([0-9]){2}|([0-9]){4}"
		me.regex = new RegExp(regexStr);
		me.regexText = Lang.get('MSG_TIME_FORMAT_REP');

		me.callParent();
	},
	//getValue 시 숫자만 리턴
	rawToValue: function(rawValue) {
		value = rawValue + "";
		value = value.replace(/[^0-9]/g, '');
		if (value === null) {
			value = rawValue || null;
		}
		return value;
	},
	//override onSpinUp (using step isn't neccessary)
	onSpinUp: function() {
		var me = this;
		if (!me.readOnly) {
			var val = parseInt(me.getValue(), 10) || 0 //gets rid of " Pack", defaults to zero on parse failure
				, nextVal = val + me.step
				, h = Math.floor(nextVal / 100) * 100
				, m = nextVal - h;

			nextVal = m > 59 ? h + 100 : nextVal;
			if (nextVal > parseInt(me.maxValue, 10)) nextVal = parseInt(me.maxValue, 10);
			me.setValue(me.setViewFormatValue(nextVal));
		}
	},
	//override onSpinDown
	onSpinDown: function() {
		var me = this;
		if (!me.readOnly) {
			var val = parseInt(me.getValue(), 10) || 0 //gets rid of " Pack", defaults to zero on parse failure
				, nextVal = (val < me.step ? parseInt(me.minValue, 10) : val - me.step)
				, h = Math.floor(nextVal / 100) * 100
				, m = nextVal - h;

			nextVal = h + (m > 59 ? 59 : m);
			me.setValue(me.setViewFormatValue(nextVal));
		}
	},
	//focus out시 format형식으로 보여주기 위함
	onChange: function(newVal, oldVal) {
		var me = this
			, v = newVal.replace(/[^0-9]/g, '');
		if (v.length >= 4) me.setValue(me.setViewFormatValue(v));
		me.callParent(arguments);
	},
	onBlur: function(e) {
		var me = this,
			v = me.rawToValue(me.getRawValue());//.replace(/[^0-9]/g,'');

		v = v.substring(0, 4);

		if (parseInt(v, 10) > parseInt(me.maxValue, 10)) v = parseInt(me.maxValue, 10);
		me.setValue(me.setViewFormatValue(v));
		me.callParent([
			e
		]);
	},
	//format형식으로 변경
	setViewFormatValue: function(value) {
		value = value + "";
		//value = value.replace(/[^0-9]/g,'');
		value = Util.lpad(String(value), 4, '0');
		if (value.length >= 4) {
			f = value.substring(0, 2)
			l = value.substring(2, value.length);

			value = f + this.formatter + l;
		}
		return value;
	}
});

