	/**
	 * 현재헤더 컬럼 정보 리턴
	 */
	columnsSave: function(event, toolEl, panelHeader) {
		var me = this
			, cols = me.getColumns()
			, idx = 0
			, rows = [];

		for (var i = 0; i < cols.length; i++) {
			var column = cols[i]
				, newColumns = []
				, level = 1
				, GROUPCODE = "";

			if (column.text != "&#160;") {		//select checkbox 제외
				if (column.ownerCt.ariaRole == "rowgroup") {
					GROUPCODE = column.getItemId();
					rows.push({
						MENUCODE: Util.nvl(CURRENT_MENUCODE, 'TOP')
						, GRID: me.getItemId()
						, GROUPCODE: GROUPCODE
						, NAME: GROUPCODE
						, LASTYN: "Y"
						, SEQ: idx
						, NODELEVEL: level
						, PARENT: GROUPCODE
						, HIDDEN: (column.isHidden() ? 'Y' : 'N')
						, HIDEABLE: (column.isHideable() ? 'Y' : 'N')
					});
					idx++;
				} else {
					column = findGroupColumn(column);
					GROUPCODE = column.getItemId();
					rows.push({
						MENUCODE: Util.nvl(CURRENT_MENUCODE, 'TOP')
						, GRID: me.getItemId()
						, GROUPCODE: GROUPCODE
						, NAME: GROUPCODE
						, LASTYN: "N"
						, SEQ: idx
						, NODELEVEL: level
						, PARENT: GROUPCODE
						, HIDDEN: (column.isHidden() ? 'Y' : 'N')
						, HIDEABLE: (column.isHideable() ? 'Y' : 'N')
					});

					idx++;
					findChildColums(column, level);
				}
			}
		}

		//최상위 column Group 찾기
		function findGroupColumn(column) {
			if (column.ownerCt.ariaRole != "rowgroup") {
				column = findGroupColumn(column.ownerCt);
			}
			return column;
		};

		//하위 column 정보생성
		function findChildColums(column, lvl) {
			lvl++;
			var num = 0;
			Ext.Array.forEach(column.items.items, function(col) {
				if (col.items.items.length == 0) {
					rows.push({
						MENUCODE: Util.nvl(CURRENT_MENUCODE, 'TOP')
						, GRID: me.getItemId()
						, GROUPCODE: GROUPCODE
						, NAME: col.getItemId()
						, LASTYN: "Y"
						, SEQ: idx
						, NODELEVEL: lvl
						, PARENT: column.getItemId()
						, HIDDEN: (col.isHidden() ? 'Y' : 'N')
						, HIDEABLE: (col.isHideable() ? 'Y' : 'N')
					});
					idx++;
					num++;
				} else {
					rows.push({
						MENUCODE: Util.nvl(CURRENT_MENUCODE, 'TOP')
						, GRID: me.getItemId()
						, GROUPCODE: GROUPCODE
						, NAME: col.getItemId()
						, LASTYN: "N"
						, SEQ: idx
						, NODELEVEL: lvl
						, PARENT: column.getItemId()
						, HIDDEN: (col.isHidden() ? 'Y' : 'N')
						, HIDEABLE: (col.isHideable() ? 'Y' : 'N')
					});
					idx++;
					num++;
					findChildColums(col, lvl);
				}
			});
			i = i + (num - 1);  //하위노드에서 실제 data Column리턴시 i++을 하면 for문의 i++과 겹쳐 사라지는 컬럼이 생김. 1건 초과분 만큼난 증가시킨다.
		}

		return rows;
	},
	/**
	 * 헤더 중첩 최대 갯수 구하기. 엑셀 다운로드용.
	 */
	getMaxColumnGroupDepth: function() {
		var me = this;
		var maxDepth = 1;
		/* 그리드 개인화 추가로 최초 그리드 생성시 게산됨.
		for(var n=0; n<me.columnGroup.length; n++)
		{
			var depth = me.getColGroupDepth(me.columnGroup[n], 1);
			if(depth > maxDepth) maxDepth = depth;
		}
		me.columnGroupDepth = maxDepth;*/
		var columns = me.columnDefine;
		for (var n = 0; n < columns.length; n++) {
			var depth = me.getColGroupDepth(columns[n], 1);
			if (depth > maxDepth) maxDepth = depth;
		}
		me.columnGroupDepth = maxDepth;

		return me.columnGroupDepth;
	},

	/**
	 * 특정 컬럼 그룹의 중첩 갯수 구하기. 엑셀 다운로드용.
	 */
	getColGroupDepth: function(colGroup, currentDepth) {
		var me = this;
		/*
		if(colGroup.columns)
		{
			if(Ext.isArray(colGroup.columns))
			{
				var maxDepth = 1;
				for(var n=0; n<colGroup.columns.length; n++)
				{
					var depth = me.getColGroupDepth(colGroup.columns[n], 1);
					if(depth > maxDepth) maxDepth = depth;
				}
				currentDepth += maxDepth;
			}
			else
			{
				currentDepth += me.getColGroupDepth(colGroup.columns, currentDepth);
			}
		}*/
		//if(colGroup.ariaRole!="rowgroup"){
		if (!Util.isNull(colGroup.columns) && colGroup.columns.length > 0) {
			currentDepth = currentDepth + 1;
			for (var n = 0; n < colGroup.columns.length; n++) {
				currentDepth = me.getColGroupDepth(colGroup.columns[n], currentDepth);
			}
		}
		return currentDepth;
	}
});

