Ext.define('VC.tab.Panel', {
	extend: 'Ext.panel.Panel'
	, alias: 'widget.vtabpanel'
	, reference: 'vtabpanel'
	, border: 0
	, layout: 'border'
	, listeners: {
		render: function(me, eOpts) {
			me.down('tabpanel').setActiveItem(0);
		}
	}

	//2017-10-24 이병옥 추가 ( extjs 6.0.1에서 6.5.2로 업그레이드 후 오류 해결)
	, getConfigurator: function() {
		return this.self.getConfigurator();
	}

	, initConfig: function(instanceConfig) {
		var me = this
			, cfg = me.getConfigurator()
			, orgItems = instanceConfig.items
			, newItems = []
			, tab = Ext.create('Ext.tab.Panel', {
				region: 'north'
				, border: 0
				, itemId: me.id + '-tab'
				, bodyStyle: "display:none;height:0px;"
				, items: []
				, listeners: {
					tabchange: function(tabPanel, newCard, oldCard, eOpts) {
						if (newCard) {
							this.up('[reference=vtabpanel]').down('[itemId=' + me.id + '-panel]').down('[id=' + newCard.getItemId() + ']').show();

							if (me.tabchangeFunc) me.tabchangeFunc(tabPanel, newCard, oldCard, eOpts);
						};
						if (oldCard) this.up('[reference=vtabpanel]').down('[itemId=' + me.id + '-panel]').down('[id=' + oldCard.getItemId() + ']').hide();

					}
				}
			})
			, panel = Ext.create('Ext.panel.Panel', {
				region: 'center'
				, itemId: me.id + '-panel'
				, flex: 1
				, border: 0
				, bodyBorder: false
				, bodyStyle: 'border:0px'
				, layout: 'fit'
				, items: []
			});

		for (var i = 0; i < orgItems.length; i++) {
			var item = orgItems[i]
				, id = Util.nvl(Util.nvl(item.id, item.idPrefix), item.itemId)
				, title = Util.nvl(item.title, id);

			delete item.title;
			item.hidden = (i > 0);
			item.setId(id);
			item.setBorder(0);
			tab.add(Ext.create('Ext.panel.Panel', { title: title, itemId: id, border: 0 }));
			panel.add(item);
		};

		newItems.push(tab);
		newItems.push(panel);

		instanceConfig.items = newItems;

		//--------------------------------------------------------------수정은 이 위로만.
		me.initConfig = Ext.emptyFn;
		//ignore subsequent calls to initConfig
		me.initialConfig = instanceConfig || {};
		cfg.configure(me, instanceConfig);
		return me;
	}
});

