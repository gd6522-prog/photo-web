						html: '<iframe id="' + newTabId + '_iframe" src="' + menuUrl + '?' + Ext.Object.toQueryString(params) + '" style="height:100%;width:100%;border:0;" frameBorder="0"></iframe>',
						searchConditionForm: '' //2022.07.26 조기근(FCV00348) 검색 조건 폼
					});

					mainContainer.setActiveTab(addedTab);
					mainContainer.addCnt++;
				} else {
					mainContainer.setActiveTab(mainContainer.getComponent(menuCode));
					//2022.07.26 조기근(FCV00348) 조회조건 값 재설정
					var searchConditionForm = mainContainer.getActiveTab().searchConditionForm;
					var keyword = JSON.parse(keyword);//ex){STRR_ID: '1002', EXPT_DELV_DT_FROM: '2022.07.14', EXPT_DELV_DT_TO: '2022.07.20', STOR_CD: '', STOR_NM: ''}
