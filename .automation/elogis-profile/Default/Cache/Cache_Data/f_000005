	/**
	 * 페이징 관련. private.
	 */
	onPageSizeKeyDown: function(field, e) {
		var me = this;
		var k = e.getKey();
		var increment = e.shiftKey ? 10 : 1;
		var allowKeys = [e.LEFT, e.RIGHT, e.DELETE, e.BACKSPACE];

		var v = Ext.getCmp(me.id + 'PageSize').getValue();
		var pageSize = parseInt(v, 10);
		var validVal = true;
		var pageSizeMax = ClientData.getSysConfig("PAGE_SIZE_MAX");
		
		if (!v || isNaN(pageSize)) {
			validVal = false;
		}
		if (k == e.RETURN) {
			e.stopEvent();
			if (validVal) {
                // 페이지당 행 갯수 제한 : PAGE_SIZE_MAX
                if(!Util.isNull(pageSizeMax)) {
                    var nPageSizeMax = parseInt(pageSizeMax);
                    // 입력된 갯수가 MAX보다 크다면
                    if(pageSize > nPageSizeMax) {
                        // 전체행수가 MAX보다 작으면 전체 행수로 셋팅
                        if(nPageSizeMax > me.paging.totalCount) {
                            pageSize = me.paging.totalCount;
                        } else {
                            // MAX로 셋팅
                            pageSize = nPageSizeMax;
                        }
                        field.setValue(pageSize);
                    }
                }
				me.paging.lastPageSize = pageSize;
				me.loadPage(1);
			}
		} else if (k == e.HOME || k == e.END) {
			e.stopEvent();
			if (k == e.END) {
                // 페이지당 행 갯수 제한 : PAGE_SIZE_MAX
                if(!Util.isNull(pageSizeMax)) {
                    var nPageSizeMax = parseInt(pageSizeMax);
                    if(me.paging.totalCount > nPageSizeMax) {
                        pageSize = nPageSizeMax;
                    } else {
                        pageSize = me.paging.totalCount;
                    }
                }
            } else {
                pageSize = 1;
            }
			field.setValue(pageSize);
		} else if (k == e.UP || k == e.PAGE_UP || k == e.DOWN || k == e.PAGE_DOWN) {
			e.stopEvent();
			if (validVal) {
				if (k == e.DOWN || k == e.PAGE_DOWN) {
					increment *= -1;
				}
				pageSize += increment;
				if (pageSize >= 1 && pageSize <= me.paging.totalCount) {
					field.setValue(pageSize);
				}
			}
		}
	},

