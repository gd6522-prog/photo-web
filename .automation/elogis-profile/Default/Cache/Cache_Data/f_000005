/**
/********************************************************************************************************
 * 2021.12.17 hjy
 * 다중정렬
 * 설정법 - 그리드 설정에 추가 - requires: ['Ext.ux.grid.MultiSort'], plugins: [{ ptype: 'multisort' }]
 * 사용법 - 그리드 헤더에서 shift 키 누른 후 사용
 ********************************************************************************************************/
Ext.define('Ext.ux.grid.MultiSort', {
	extend: 'Ext.AbstractPlugin',
	alias: 'plugin.multisort',
	mixins: {
		observable: 'Ext.util.Observable'
	},

	// @public
	//	showToolTip: true
	//	sortTipText: 'Sorted by:',

	// @private
	_sortCols: [],
	_grid: undefined,
	_toolTip: undefined,

	init: function(grid) {
		var me = this;

		grid.on({
			beforedestroy: me.unsetup,
			reconfigure: me.resetup,
			scope: me
		});

		me.setup(grid);
	},

	// private
	setup: function(grid) {
		var me = this;
		me._grid = grid;

		Ext.each(me._grid.headerCt.getGridColumns(), function(c) {
			c.origSortable = c.sortable; //Add This
			c.sortable = false;
			c.on('headerclick', me.onColumnClicked, me);
		}, me);
	},

	onColumnClicked: function(header, col, e, t, eOpts) {
		var me = this,
			sorters = [],
			data1,
			data2;

		e.stopEvent();

		if (!col.origSortable) //Add This
			return;

		if (e.shiftKey) {
			Ext.each(me._sortCols, function(c) {
				if (c.sortState) {
					if (c.id !== col.id) {
						if (!Util.isNull(me._grid.comboColumnStore[c.dataIndex])) {
							sorters.push({
								property: c.dataIndex,
								direction: c.sortState,
								sorterFn: function(v1, v2) {
									v1 = v1.get(c.dataIndex);
									v2 = v2.get(c.dataIndex);

									data1 = me._grid.comboColumnStore[c.dataIndex].findRecord('CODE', v1);
									data2 = me._grid.comboColumnStore[c.dataIndex].findRecord('CODE', v2);

									if (Util.isNull(data1)) {
										data1 = "";
									} else {
										data1 = data1.get("NAME");
									}

									if (Util.isNull(data2)) {
										data2 = "";
									} else {
										data2 = data2.get("NAME");
									}

									return data1 > data2 ? 1 : (data1 < data2 ? -1 : 0);
								}
							});
						} else {
							sorters.push({
								property: c.dataIndex,
								direction: c.sortState
							});
						}
					}
				}
			});
		} else {
			Ext.each(me._sortCols, function(c) {
				if (c.sortState) {
					// if its not the column that was clicked OR, we were previously multi-sorting, clear sortState and remove icons
					if ((c.id !== col.id) || (me._sortCols.length > 1)) {
						c.setSortState(undefined, true, true);
					}
				}
			});
			me._sortCols = [];
		}

		if (!Util.isNull(me._grid.comboColumnStore[col.dataIndex])) {
			sorters.push({
				property: col.dataIndex,
				direction: me.getDirection(col),
				sorterFn: function(v1, v2) {
					v1 = v1.get(col.dataIndex);
					v2 = v2.get(col.dataIndex);

					data1 = me._grid.comboColumnStore[col.dataIndex].findRecord('CODE', v1);
					data2 = me._grid.comboColumnStore[col.dataIndex].findRecord('CODE', v2);

					if (Util.isNull(data1)) {
						data1 = "";
					} else {
						data1 = data1.get("NAME");
					}

					if (Util.isNull(data2)) {
						data2 = "";
					} else {
						data2 = data2.get("NAME");
					}

					return data1 > data2 ? 1 : (data1 < data2 ? -1 : 0);
				}
			});
		} else {
			sorters.push({
				property: col.dataIndex,
				direction: me.getDirection(col)
			});
		}

		me.addSortColumn(col);

		me._grid.store.sort(sorters);

		//		me.createToolTip();
	},

	addSortColumn: function(col) {
		var me = this,
			exists = false,
			colToMove = undefined;

		Ext.each(me._sortCols, function(c) {
			if (c.id === col.id) {
				colToMove = c
				exists = true;
			}
		});

		if (colToMove) {
			Ext.Array.remove(me._sortCols, colToMove);
			Ext.Array.push(me._sortCols, colToMove);
		}

		if (!exists) {
			me._sortCols.push(col);
		}
	},

	getDirection: function(col) {
		var dir;

		dir = (col.sortState == 'ASC') ? 'DESC' : 'ASC';

		//		col.setSortState(dir, true, true);

		return dir;
	},

	//	createToolTip: function () {
	//		var me = this,
	//            tip = '';
	//
	//		if (me.showToolTip) {
	//			me.clearToolTip();
	//
	//			Ext.each(me._sortCols, function (c) {
	//				tip += '<br/>' + c.text;
	//			});
	//
	//			me._toolTip = Ext.create('Ext.tip.ToolTip', {
	//				target: me._grid.headerCt.el,
	//				html: me.sortTipText + tip,
	//				renderTo: Ext.getBody()
	//			});
	//		}
	//	},

	// @public
	//	clearToolTip: function () {
	//		var me = this;
	//		if (me._toolTip) {
	//			me._toolTip.setTarget(undefined);
	//			Ext.destroy(me._toolTip);
	//		}
	//	},

	// private
	unsetup: function(grid) {
		var me = this;

		//		me.clearToolTip();
		me._grid = null;
	},

	resetup: function(grid) {
		this.unsetup(grid);
		this.setup(grid);
	}

});

