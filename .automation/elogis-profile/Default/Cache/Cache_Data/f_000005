	if (!Util.isNull(findColNm)) {
		for (var c = 1; c < columns.length; c++) {
			if (columns[c].dataIndex == findColNm) {
				rtnColumIdx = c - 1;
				break;
			}
		}
	}

	return rtnColumIdx;
}
/*******************************************************************************
 * 2021.12.28 조기근(FCV00348) 그리드 첫번째 행 선택
 * 2022.03.30 조기근(FCV00348) 파라메터 rowIdx 추가, rowIdx > 0 이면, 해당 행 선택
 ******************************************************************************/
function setSelectedFirstRow(grid, store, rowIdx) {
	var length = store.getData().length;
	if (length > 0) {
		if (rowIdx > 0) {
			var record = store.getAt(rowIdx);
			grid.selModel.select(record);
			grid.lastSelectedRowIdx = rowIdx;
			grid.lastSelectedRow = record;
		} else {
			var record = store.getAt(0);
			grid.selModel.select(record);
			grid.lastSelectedRowIdx = 0;
			grid.lastSelectedRow = record;
		}
	}
}
