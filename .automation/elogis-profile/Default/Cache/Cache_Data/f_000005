	setFormData: function(formItem) {
		var fieldList = new Array();

		for (var i = 0; i < formItem.length; i++) {
			if ("textfield" == formItem[i].type) {
				var fieldValue = {
					xtype: 'textfield',
					id: Util.nvl(formItem[i].id, formItem[i].name),
					labelWidth: Util.nvl(formItem[i].labelWidth, 70),
					width: Util.nvl(formItem[i].width, 170),
					readOnly: Util.nvl(formItem[i].valueReadOnly, false),
					margin: Util.nvl(formItem[i].margin, '0 30 0 0'),
					fieldLabel: Lang.get(formItem[i].name),
					value: formItem[i].value,
					textAlign: formItem[i].textAlign,
					hidden: formItem[i].hidden,
					style: formItem[i].style
				}

				if (!Util.isNull(formItem[i].listeners)) {
					fieldValue.listeners = formItem[i].listeners;
				}

				fieldList.push(fieldValue);
			} else if ("pop" == formItem[i].type) {
				var id = formItem[i].name;
				var name = formItem[i].name;
				var title = formItem[i].TITLE;

				//var dbCol = formItem[i].DBCOLUMN;
				var value = formItem[i].DEFAULTVALUE;
				var fieldValue = {
					xtype: 'popSearchField',
					param: {
						CODE_HEADER: formItem[i].CODE_HEADER,
						CODE_COLNAME: formItem[i].CODE_COLNAME,
						NAME_HEADER: formItem[i].NAME_HEADER,
						NAME_COLNAME: formItem[i].NAME_COLNAME,
						DEFAULTVALUESET: formItem[i].DEFAULTVALUESET,
						SQLPROP: formItem[i].SQLPROP,
						KEYPARAM: formItem[i].KEYPARAM,
						PARAM1: formItem[i].PARAM1,
						PARAM2: formItem[i].PARAM2,
						PARAM3: formItem[i].PARAM3,
						MODULE: formItem[i].MODULE,
						COLUMNDESCR_LANG: Lang.get(formItem[i].DBCOLUMN),
						WIDTH: formItem[i].WIDTH,
						HEIGHT: formItem[i].HEIGHT,
						PAGESIZE: formItem[i].PAGESIZE,
						afterGetRow: formItem[i].afterGetRow,
						editable: formItem[i].valueEditable,
						TITLE: Util.nvl(title, 'NEW'),
						setCodeValue: function(value, name, id) {
							if (id != undefined) {
								Ext.getCmp(id).setValue(value);
							} else {
								Ext.getCmp(name).setValue(value);
							}
						},
						RETURNROW: formItem[i].RETURNROW,
						CALLBY: formItem[i].CALLBY
					},
					editable: Util.nvl(formItem[i].valueEditable, false),
					CURRENT_MENUCODE: CURRENT_MENUCODE,
					customPopupFunction: Util.nvl(formItem[i].customPopupFunction, ''),
					id: id,
					labelWidth: Util.nvl(formItem[i].labelWidth, 70),
					width: Util.nvl(formItem[i].width, 170),
					margin: Util.nvl(formItem[i].margin, '0 30 0 0'),
					fieldLabel: Lang.get(id),
					format: ClientData.getFormat(Util.nvl(formItem[i].dateRenderFormat, formItem[i].renderFormat))
				}

				if (!Util.isNull(formItem[i].listeners)) {
					fieldValue.listeners = formItem[i].listeners;
				}

				fieldList.push(fieldValue);
			} else if ("combo" == formItem[i].type) {
				var comboStore = formItem[i].comboStore;
				var valueField = 'CODE';
				var displayField = 'NAME';

				if (!Util.isNull(formItem[i].comboStore)) {
					valueField = Util.nvl(formItem[i].comboValueField, comboStore.model.getFields()[0].name);
					displayField = Util.nvl(formItem[i].comboDisplayField, comboStore.model.getFields()[1].name);
				}

				var id = formItem[i].name;
				var fieldValue = {
					xtype: 'combobox',
					queryMode: 'local',
					displayField: displayField,
					valueField: valueField,
					fieldLabel: Lang.get(id),
					labelWidth: Util.nvl(formItem[i].labelWidth, 80),
					width: Util.nvl(formItem[i].width, 170),
					editable: Util.nvl(formItem[i].valueEditable, true),
					margin: Util.nvl(formItem[i].margin, '0 30 0 0'),
					id: id,
					store: comboStore
				}

				if (!Util.isNull(formItem[i].listeners)) {
					fieldValue.listeners = formItem[i].listeners;
				}

				fieldList.push(fieldValue);
			}
		}
		return fieldList;
