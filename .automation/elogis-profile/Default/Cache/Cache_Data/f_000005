		me.paging.totalCount = totalCnt;
		me.store.firstNumberOfPage = 1;
		me.paging.lastPageSize = Util.nvl(me.paging.lastPageSize, me.pageSize);
		Ext.getCmp(me.id + 'PageSize').enable();
