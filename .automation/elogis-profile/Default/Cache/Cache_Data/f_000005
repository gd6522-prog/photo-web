					//팝업창에 파라미터 넘기고 팝업창이 닫힐 때 onPopClose 를 호출한다.
					me.popWinOpened = true;
					if (me.customPopupFunction) {
						//2021.12.06 조기근(FCV00348) 필드에 입력한 값을 팝업 창 검색 조건에 보여주기 위해 param.DEFAULTVALUE 추가
						param.DEFAULTVALUE = me.value;
						me.customPopupFunction(param);
					}
					else {
						//2021.11.26 조기근(FCV00348) 필드에 입력한 값을 팝업 창 검색 조건에 보여주기 위해 param.DEFAULTVALUE 추가
						param.DEFAULTVALUE = me.value;
						VC.components.CommonSearchPop.show(param);
					}
				}
			}
