function getColumn(grid, findColNm) {
	var columns = grid.columns;//전체 컬럼
	var rtnColum = null;//리턴 컬럼
	if (!Util.isNull(findColNm)) {
		for (var c = 0; c < columns.length; c++) {
			if (columns[c].dataIndex == findColNm) {
				rtnColum = columns[c];
				break;
			}
		}
	}
	return rtnColum;
}

