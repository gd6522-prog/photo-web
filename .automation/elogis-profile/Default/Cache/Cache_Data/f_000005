				});
				mainContainer.fireTabChangeEvent = true;
				mainContainer.setActiveTab(addedTab);
				mainContainer.addCnt++;
				mainContainer.fireEvent('remove');
			} else { // 자동 추가면 탭 추가.
				var params = {
					MENUCODE: menuCode,
					MENUPATH: encodeURIComponent(menuFullPath),
					APP: app,
					KEYWORD_INDEX: keywordIndex,
