	/**
	 * 헤더 중첩 최대 갯수 구하기. 엑셀 다운로드용.
	 */
	getMaxColumnGroupDepth: function() {
		var me = this;
		var maxDepth = 1;
		/* 그리드 개인화 추가로 최초 그리드 생성시 게산됨.
		for(var n=0; n<me.columnGroup.length; n++)
		{
			var depth = me.getColGroupDepth(me.columnGroup[n], 1);
			if(depth > maxDepth) maxDepth = depth;
		}
		me.columnGroupDepth = maxDepth;*/
		var columns = me.columnDefine;
		for (var n = 0; n < columns.length; n++) {
			var depth = me.getColGroupDepth(columns[n], 1);
			if (depth > maxDepth) maxDepth = depth;
		}
		me.columnGroupDepth = maxDepth;

		return me.columnGroupDepth;
	},

	/**
	 * 특정 컬럼 그룹의 중첩 갯수 구하기. 엑셀 다운로드용.
	 */
	getColGroupDepth: function(colGroup, currentDepth) {
		var me = this;
		/*
		if(colGroup.columns)
		{
			if(Ext.isArray(colGroup.columns))
			{
				var maxDepth = 1;
				for(var n=0; n<colGroup.columns.length; n++)
				{
					var depth = me.getColGroupDepth(colGroup.columns[n], 1);
					if(depth > maxDepth) maxDepth = depth;
				}
				currentDepth += maxDepth;
			}
			else
			{
				currentDepth += me.getColGroupDepth(colGroup.columns, currentDepth);
			}
		}*/
		//if(colGroup.ariaRole!="rowgroup"){
		if (!Util.isNull(colGroup.columns) && colGroup.columns.length > 0) {
			currentDepth = currentDepth + 1;
			for (var n = 0; n < colGroup.columns.length; n++) {
				currentDepth = me.getColGroupDepth(colGroup.columns[n], currentDepth);
			}
		}
		return currentDepth;
	},

	/**
	 * 최하위 컬럼 정의로 상위 헤더들의 텍스트 리스트를 생성한다. 엑셀 다운로드용.
	 */
	//setParentHeaderTextArr : function(paramsForExcelDown, colName, header)
	//setParentHeaderTextArr : function(cols)
	//2022.02.07 조기근(FCV00348) 파라메터 params 추가
	setParentHeaderTextArr: function(cols, params) {
		var me = this;
		/*
		if(me.columnGroup)
		{
			for(var n=0; n<me.columnGroup.length; n++)
			{
				var tempArr = [];
				if(me.isColNameInGroup(me.columnGroup[n], colName, tempArr))
				{
					//console.log(tempArr);
					for(var d=0; d<params.EXCEL_HEADER_DEPTH-1; d++)
					{
						var headerText = header;
						if(!Util.isNull(tempArr[d]))
						{
							headerText = tempArr[d];
						}
						params['EXCEL_HEADER_GROUP_' + d].push(headerText);
					}
				}
			}
		}*/
		if (me.columnGroupDepth > 1) {

			//column 레벨별로 분기
			var group = [];				//header setting
			var merge = [];				//merge 좌표 [1,1,2,2#1,2,3,3#.......]
			var level = 0;				//header rows
			var colIndex = 0;			//merge column 좌표 계산을 위함
			for (var i = 0; i < me.columnDefine.length; i++) {
				var col = me.columnDefine[i];
				var num = 1;

				//제외 컬럼
				//				if(col.type == 'gridrownumber') continue;																						//넘버러, 선택 체크박스 제외
				//				if(Util.nvl(col.hidden,false) || !Util.nvl(col.hideable,true) || col.width == '0' || !Util.nvl(col.excelout,true) ) continue;	//그리드에서 숨김 컬럼은 제외

				// hjy 2022.03.03 변경
				// hjy 2022.04.25 변경 - 2 depth 헤더인 grid에서 엑셀다운로드 시 헤더 컬럼을 드래그로 순서 번경하면 undefined 나오는 오류 수정
				if (Util.isNull(col) || col.type == 'gridrownumber') continue; //넘버러, 선택 체크박스 제외

				if (Util.nvl(params.SHOW_HIDEABLE_COL, false)) {
					if (col.width == '0' || !Util.nvl(col.excelout, true)) continue; //그리드에서 숨김 컬럼도 엑셀 다운로드
				} else {
					if (Util.nvl(col.hidden, false) || !Util.nvl(col.hideable, true) || col.width == '0' || !Util.nvl(col.excelout, true)) continue; //그리드에서 숨김 컬럼은 제외
				}

				var header = Util.nvl(col.header, col.colName);

				if (Util.isNull(group[level])) group[level] = [];	//최초입력시
				//자식컬럼이 존재시
				if (!Util.isNull(col.columns)) {
					num = subGroupHeader(col.columns, level, colIndex);
					if (num > 1) {	//merge 좌표생성
						if (colIndex != colIndex + num - 1) merge.push([level, 0, colIndex, colIndex + (num - 1)].toString());
					}
					colIndex = colIndex + (num - 1);
					//자식컬럼이 미 존재시
				} else {
					if (level != me.columnGroupDepth - 1) merge.push([level, me.columnGroupDepth - 1, colIndex, colIndex].toString());
				}
				if (num > 1) {
					//파생자식 수 만큼 현재 헤더를 반복생성
					for (var j = 0; j < num; j++)	group[level].push(header);
				} else {
					//header rows 길이를 맞추기 위해 전체 header정보를 확인. 추가생성
					for (var j = 0; j < group.length; j++) {
						if (group[level].length == group[j].length && j != level) group[j].push(header);
					}
					group[level].push(header);
				}
				colIndex++;
			}
			//submit header 정보
			for (var n = 0; n < params.EXCEL_HEADER_DEPTH - 1; n++) {
				params['EXCEL_HEADER_GROUP_' + n] = group[n].toString();
			}
			//submit merge 정보
			var str = "";
			for (var n = 0; n < merge.length; n++) {
				str += (n > 0 ? "#" : "") + merge[n];
			}
			params['EXCEL_HEADERMERGE'] = str;
		}

		//하위 header 컬럼정보생성
		//부모로 부터 파생된 최종컬럼 수 리턴
		function subGroupHeader(cols, lvl, colIdx) {
			var level = lvl + 1;
			var idx = 0;
			var cnt = 0;		//실제보여지는 컬럼수가 필요함

			if (Util.isNull(group[level])) {
				group[level] = Ext.clone(group[lvl]);
			}
			for (var n = 0; n < cols.length; n++) {
				var col = cols[n];
				var num = 1;
				var header = Util.nvl(col.header, col.colName);
				//넘버러, 선택 체크박스 제외
				if (col.type == 'gridrownumber') continue;

				if (Util.nvl(params.SHOW_HIDEABLE_COL, false)) {
					if (col.width == '0' || !Util.nvl(col.excelout, true)) continue; //그리드에서 숨김 컬럼도 엑셀 다운로드
				} else {
					//그리드에서 숨김 컬럼은 제외
					if (Util.nvl(col.hidden, false) || !Util.nvl(col.hideable, true) || col.width == '0' || !Util.nvl(col.excelout, true)) continue;
				}

				if (n > 0) {
					colIdx = colIdx + 1;
				}
				if (!Util.isNull(col.columns)) {
					num = subGroupHeader(col.columns, level, colIdx);
					if (num > 1) {
						if (colIdx != colIdx + num - 1) merge.push([level, level, colIdx, colIdx + (num - 1)].toString());
					}
					colIdx = colIdx + (num - 1); // hjy 2022.03.03 추가
					idx = idx + (num - 1);
				} else {
					if (level != me.columnGroupDepth - 1) merge.push([level, me.columnGroupDepth - 1, colIdx, colIdx].toString());
				}
				if (num > 1) {
					for (var j = 0; j < num; j++)	group[level].push(header);
				} else {
					group[level].push(header);
				}
				cnt += 1;
			}
			return cnt + idx;
		}
	},
	/**
	 * 특정 컬럼 그룹에 colName 이 있는지 체크. 엑셀 다운로드용.
	 */
	isColNameInGroup: function(colGroupDefine, colName, tempArr) {
		var me = this;
		if (colGroupDefine.colName == colName) {
			return true;
		}
		else if (colGroupDefine.columns) {
			if (Ext.isArray(colGroupDefine.columns)) {
				for (var cols = 0; cols < colGroupDefine.columns.length; cols++) {
					if (typeof colGroupDefine.columns[cols] == 'string') {
						if (colGroupDefine.columns[cols] == colName) {
							tempArr.unshift(colGroupDefine.header);
							return true;
						}
					}
					else if (typeof colGroupDefine.columns[cols] == 'number') {
						var columnDefine = me.columnDefine[colGroupDefine.columns[cols]];
						if (Util.nvl(columnDefine.colName, columnDefine.header) == colName) {
							tempArr.unshift(colGroupDefine.header);
							return true;
						}
					}
					else if (colGroupDefine.columns[cols].header && colGroupDefine.columns[cols].columns) {
						if (me.isColNameInGroup(colGroupDefine.columns[cols], colName, tempArr)) {
							tempArr.unshift(colGroupDefine.header);
							return true;
						}
					}
				}
			}
		}
	},

