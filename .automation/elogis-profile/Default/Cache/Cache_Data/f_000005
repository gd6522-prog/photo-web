	/**
	 * 2022-07-12 hjy
	 * 참조 : oms-custom-popup.js - openAllWhCdPop function
	 * 팝업용 다중 선택 후 신규 행 추가.
	 * record - 팝업 창에서 선택한 대상의 데이터
	 * addRecordData - main grid 의 기초데이타 추가할 때
	 * record 의 key 와 추가 할려는 main grid -> colName 명칭이 똑같아야지 적용됨
	 * 2022-08-31 hjy
	 * clearData 추가
	 * clearData - record & addRecordData 에 해당하는 컬럼 제외하고 main grid 의 나머지 컬럼 데이터들을 clear할지 말지 결정
	 */
	multiAddRow: function(record, addRecordData, clearData) {
		if (!Util.isNull(record)) {
			var me = this;
			var newRow = {}
			var startIndex = me.lastSelectedRowIdx;
			var currentIndex = me.lastSelectedRowIdx;
			var parsingData = {};
			var parsingData2 = {};

			me.store.suspendEvents();

			for (var i = 0; i < record.length; i++) {
				parsingData = Object.assign({}, record[i], addRecordData);
				parsingData2 = Ext.clone(parsingData);

				newRow = Ext.create(me.id + 'Model', Util.nvl(parsingData2, {}));

				if (i == 0) {
					delete parsingData.ROW_DELETE;
					delete parsingData.ROW_NO;
					delete parsingData.ROW_STATUS;
					delete parsingData.ROW_STATUS_TXT;

					// 행 추가 안하고 바로 선택 후 행 추가 시 세팅
					if (currentIndex == -1) {
						currentIndex = 0;

						newRow.set('ROW_STATUS_TXT', Lang.get('INSERT'));
						newRow.set('ROW_STATUS', 'I');
						me.store.insert(currentIndex, newRow);
					}

					if (Util.nvl(clearData, false)) {
						me.store.getAt(currentIndex).set(parsingData2);
					} else {
						me.store.getAt(currentIndex).set(parsingData);
					}

					me.getSelectionModel().select(currentIndex);
					me.lastSelectedRowIdx = currentIndex;
					me.lastSelectedRow = me.store.getAt(currentIndex);
				} else {
					if (Util.nvl(me.editable, true) || Util.nvl(me.popEditable, false)) {
						newRow.set('ROW_STATUS_TXT', Lang.get('INSERT'));
						newRow.set('ROW_STATUS', 'I');
					}

					currentIndex = me.lastSelectedRowIdx + 1;
					me.store.insert(currentIndex, newRow);

					me.getSelectionModel().select(newRow);
					me.lastSelectedRowIdx = currentIndex;
					me.lastSelectedRow = newRow;
				}
			}

			me.store.resumeEvents(false);

			if (me.useCheckboxModel) {
				me.getSelectionModel().getSelected().clear();
				me.getSelectionModel().selectRange(startIndex, record.length + startIndex - 1);
			}

			if (me.getStore().getSorters().length > 0) {
				me.getStore().getSorters().clear();
			}

			me.resetTitleText(null, me.store.count());
			me.getView().refresh();
		}
	},
