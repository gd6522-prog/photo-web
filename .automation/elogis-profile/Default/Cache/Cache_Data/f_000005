		isValidPassword: function(value, id, fieldName) {
			var rtnMsg = fieldName + (Util.isNull(fieldName) ? '' : ': ')
				, alphabet = /[A-Za-z]/.test(value)
				, number = /[0-9]/.test(value)
				, special = /\W/.test(value);

			if (Util.isNull(value)) return rtnMsg + Lang.get('MSG_REQUIRED_FIELD');													//필수 입력란 입니다.
			if (value.length < (special ? 8 : 10)) return rtnMsg + Lang.getRep("MSG_MIN_LENGTH", [(special ? 8 : 10)]);								//{0} 이상으로 입력해 주십시오.
			if (value.indexOf(id) > -1) return rtnMsg + Lang.getRep("NONE_INDEXOF", ["ID"]);											//{0}을(를) 포함 할 수 없습니다.
			if (/[\s\u00A0]/.test(value)) return rtnMsg + Lang.getRep("NONE_INDEXOF", [Lang.get("STRING_SPACE")]);						//공백문자 {0}을(를) 포함 할 수 없습니다.
			if (/[\<\>\'\;\\\,\&\~]/.test(value)) return rtnMsg + Lang.getRep("NONE_INDEXOF", [Lang.get("STRING_SPECIAL")]) + "[ <,>,',;,\\,& ]";	//튼수문자 {0}을(를) 포함 할 수 없습니다.
			if (!alphabet || !number) return rtnMsg + Lang.get("INDEXOF_ALNUM");														//영문과 숫자가 조합되어야 합니다.
			if (/([\w\W])\1\1/.test(value)) return rtnMsg + Lang.getRep("NONE_INDEXOF_LOOPSTR", [3]);										//연속 {0}회 이상 반복되는 동일문자를 포함 할 수 없습니다.

