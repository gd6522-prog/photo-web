	},
	/**
	 * 헤더 상세 설정. private
	 * gridColumn : exj 객체
	 * col        : dev source setting
	 * modelField : model 필드명
	 */
	setGridColumn: function(gridColumn, col, modelField) {
		var me = this;
		//기본 값
		if (col.defaultValue) {
			modelField.defaultValue = col.defaultValue;
		}

		if (col.type == 'treecolumn') {
			modelField.type = 'string';
			gridColumn.xtype = 'treecolumn';
			gridColumn.tdCls = gridColumn.tdCls.replace('grid-column', 'grid-treecolumn');
			if (Util.nvl(me.editable, true) && Util.nvl(col.editable, true)) {
				gridColumn.editor = {};
			}
		}
		//int 나 float 타입
		if (col.type == 'int' || col.type == 'float' || col.type == 'number') {
			modelField.type = col.type;
			col.align = 'right';
			gridColumn.align = 'right';
			gridColumn.xtype = 'numbercolumn';
			if (col.format) {
				gridColumn.format = col.format;
			} else {
				gridColumn.format = col.type == 'int' ? ClientData.getFormat('INT_FORMAT') : ClientData.getFormat('FLOAT_FORMAT');
			}
			if (Util.nvl(me.editable, true) && Util.nvl(col.editable, true)) {
				gridColumn.editor = {
					xtype: 'numberfield'
				};
				var num = 0;
				if (gridColumn.format.indexOf('.') > -1) {
					num = gridColumn.format.substring(gridColumn.format.indexOf('.') + 1, gridColumn.format.length).length;
				}
				if (!Util.isNull(col.decimalPrecision) || gridColumn.format.indexOf('.') > -1) {
					gridColumn.editor.decimalPrecision = Util.nvl(col.decimalPrecision, 0) > num ? Util.nvl(col.decimalPrecision, 0) : num;
				}

				if (!Util.isNull(col.step)) gridColumn.editor.step = col.step;
				if (!Util.isNull(col.minValue)) gridColumn.editor.minValue = col.minValue;
				if (!Util.isNull(col.maxValue)) gridColumn.editor.maxValue = col.maxValue;
			}
		}
		//checkbox 타입
		else if (col.type == 'checkbox') {
			col.align = 'center';
			modelField.type = 'boolean';
			gridColumn.xtype = 'checkcolumn';
			gridColumn.stopSelection = false;
			if (!Util.nvl(me.editable, true) || !Util.nvl(col.editable, true)) {
				gridColumn.listeners = {
					beforecheckchange: function(checkcolumn, rowIdx, checked, opts) {
						return false;
					}
				};
			}
			else {
				gridColumn.listeners = {
					//그리드 체크컬럼은 beforeedit, edit 리스너가 안먹힌다!!! 그래서 이렇게 함...
