			else if (!me.verifyUserPwUpper(pw)) {
				rtn = "FAIL";
				rtnMsg = Lang.getRep("MSG_PW_CONTAIN_REQUIRED", ["대문자"])/* 비밀번호에 대문자는(은) 필수로 포함되어야 합니다. */;
			}
			//소문자 체크
			else if (!me.verifyUserPwLower(pw)) {
				rtn = "FAIL";
				rtnMsg = Lang.getRep("MSG_PW_CONTAIN_REQUIRED", ["소문자"])/* 비밀번호에 소문자는(은) 필수로 포함되어야 합니다. */;
			}
			//숫자 체크
			else if (!me.verifyUserPwNumber(pw)) {
				rtn = "FAIL";
				rtnMsg = Lang.getRep("MSG_PW_CONTAIN_REQUIRED", ["숫자"])/* 비밀번호에 숫자는(은) 필수로 포함되어야 합니다. */;
			}
			//특수문자 체크
			else if (!me.verifyUserPwSpecialChar(pw)) {
				rtn = "FAIL";
				rtnMsg = Lang.getRep("MSG_PW_CONTAIN_REQUIRED", ["특수문자"])/* 비밀번호에 특수문자는(은) 필수로 포함되어야 합니다. */;
			}
			//연속된 값 체크
			else if (!me.verifyUserPwConsecutive(pw)) {
				rtn = "FAIL";
				rtnMsg = Lang.get("MSG_PW_NO_CONSECUTIVE")/* 비밀번호에 연속된 문자(숫자)를 사용할 수 없습니다. */;
			}
			//개인정보 값 체크
			else if (!me.verifyUserPwPersonalInfo(pw, id)) {
				rtn = "FAIL";
				rtnMsg = Lang.get("MSG_PW_NO_PERSONAL_INFO");/* 비밀번호에 개인정보를 포함 할 수 없습니다. */;
			}
			//최근 비밀번호 재사용 체크
			else if (!Util.isNull(me.verifyUserPwReuse(pw, id)) && !me.verifyUserPwReuse(pw, id)) {
				rtn = "FAIL";
				rtnMsg = Lang.get("MSG_PW_NO_REUSE")/* 이전에 사용된 비밀번호는 사용 할 수 없습니다. */;
			}

			arrRtn[0] = rtn;
			arrRtn[1] = rtnMsg;

			return arrRtn;
		},

		/**
		 * PASSWORD 길이 체크
		 */
		verifyUserPwLen: function(pw) {
			var rtn = true;

			var pwLenMinLim = ClientData.getSysConfig("PASSWORD_LENGTH_MIN_LIMIT");
			var pwLenMaxLim = ClientData.getSysConfig("PASSWORD_LENGTH_MAX_LIMIT");

			if (pw.length < pwLenMinLim || pw.length > pwLenMaxLim) {
				rtn = false;
			}

			return rtn;
		},

		/**
		 * PASSWORD 대문자 체크
		 */
		verifyUserPwUpper: function(pw) {
			var rtn = true;

			var pwChkYn = ClientData.getSysConfig("PASSWORD_UPPERCASE_REQ_YN");

			if (!Util.isNull(pwChkYn) && pwChkYn == 'Y') {
				var re = new RegExp("[A-Z]");
				rtn = re.test(pw);
			}

			return rtn;
		},

		/**
		 * PASSWORD 소문자 체크
		 */
		verifyUserPwLower: function(pw) {
			var rtn = true;

			var pwChkYn = ClientData.getSysConfig("PASSWORD_LOWERCAS_REQ_YN");

			if (!Util.isNull(pwChkYn) && pwChkYn == 'Y') {
				var re = new RegExp("[a-z]");
				rtn = re.test(pw);
			}

			return rtn;
		},

		/**
		 * PASSWORD 숫자 체크
		 */
		verifyUserPwNumber: function(pw) {
			var rtn = true;

			var pwChkYn = ClientData.getSysConfig("PASSWORD_NUMERIC_REQ_YN");

			if (!Util.isNull(pwChkYn) && pwChkYn == 'Y') {
				var re = new RegExp("[0-9]");
				rtn = re.test(pw);
			}

			return rtn;
		},

		/**
		 * PASSWORD 특수문자 체크
		 */
		verifyUserPwSpecialChar: function(pw) {
			var rtn = true;

			var pwChkYn = ClientData.getSysConfig("PASSWORD_SPECIAL_CHAR_REQ_YN");

			if (!Util.isNull(pwChkYn) && pwChkYn == 'Y') {
				//var re = new RegExp("[!@#$%^&()]"); //* 는 제외
				var re = new RegExp('[`~!@#$%^&*()\'\";:?]'); //* 는 제외
				rtn = re.test(pw);
			}

			return rtn;
		},

		/**
		 * PASSWORD 연속된 값 체크(123 or 111)
		 */
		verifyUserPwConsecutive: function(pw, max) {
			var rtn = true;
			if (!max) max = 3;

			var pwChkYn = ClientData.getSysConfig("PASSWORD_NO_CONTINUE_VALUE_YN");

			if (!Util.isNull(pwChkYn) && pwChkYn == 'Y' && pw.length >= max) {

				var i, j, k, x, y;
				var buff = ["0123456789", "abcdefghijklmnopqrstuvwxyz", "ABCDEFGHIJKLMNOPQRSTUVWXYZ"];
				var src, src2, ptn = "";

				for (i = 0; i < buff.length; i++) {
					src = buff[i]; // 0123456789
					src2 = buff[i] + buff[i]; // 01234567890123456789
					for (j = 0; j < src.length; j++) {
						x = src.substr(j, 1); // 0
						y = src2.substr(j, max); // 012
						ptn += x + "{" + max + ",}|"; // 0{3,}|012|1{3,}|123|...
						ptn += y + "|";
					}
				}

				ptn = new RegExp(ptn.replace(/.$/, ""))/* 맨마지막의 글자를 하나 없애고 정규식으로 만든다. */;

				if (ptn.test(pw)) {
					rtn = false;
				} else {
					rtn = true;
				}
			}

			return rtn;
		},

		/**
		 * PASSWORD 개인정보 값 체크
		 */
		verifyUserPwPersonalInfo: function(pw, id) {
			var rtn = true;

			var pwChkYn = ClientData.getSysConfig("PASSWORD_NO_PRIVACY_VALUE_YN");

			if (!Util.isNull(pwChkYn) && pwChkYn == 'Y') {
				if (!Util.isNull(id) && pw.toLowerCase().indexOf(id.toLowerCase()) > -1) {
					rtn = false;
				}
			}

			return rtn;
		},

		/**
		 * PASSWORD 재사용 체크
		 */
		verifyUserPwReuse: function(pw, id) {
			var rtn;//= true;

			var pwChkYn = ClientData.getSysConfig("PASSWORD_NO_REUSE_COUNT");

			pwChkYn = parseInt(Util.nvl(pwChkYn, 0));

			if (pwChkYn > 0 && !Util.isNull(id)) {

				//최대 5회로 제한
				if (pwChkYn > 5) pwChkYn = 5;

				Ext.Ajax.request({
					async: false,
					url: '/userService/searchUserPwHis',
					params: {
						USERID: id,
						PASSWORD: Util.commonEncode(pw),
						REUSE_COUNT: pwChkYn
					},
					callback: function(options, success, response) {
						var json = Util.isNull(response.responseText) ? { ErrorMsg: 'Sever Response Failed!!' } : Ext.decode(response.responseText);
						if (json["ErrorMsg"] === "OK") {
							var result = json["DS_OUT"];
							if (result.length > 0) {
								rtn = false;
							} else {
								rtn = true;
							}

							return rtn;
						}
						else {
							Ext.MessageBox.show({
								msg: json["ErrorMsg"],
								buttons: Ext.MessageBox.OK,
								icon: Ext.MessageBox.ERROR
							});
						}
					}
				});
			}
			return rtn;
		}
	}
});

/* Ext.MessageBox 스페이스바 키 이벤트시 중복 콜백 호출 버그 개선 */
Ext.define('App.util.MessageBox', {
    singleton: true,

    _createProtectedCallback: function(callbackFn, scope) {
        var alreadyHandled = false;

        var spaceKeyHandler = function(e) {
            if (e.getKey() === Ext.EventObject.SPACE) {
                e.stopEvent();
            }
        };

        Ext.getDoc().on('keydown', spaceKeyHandler);

        return function(btn, text) {
            Ext.getDoc().un('keydown', spaceKeyHandler);

            if (alreadyHandled) return;
            alreadyHandled = true;

            if (typeof callbackFn === 'function') {
                callbackFn.call(scope || this, btn, text);
            }
        };
    },

    confirm: function(title, message, callbackFn, scope) {
        Ext.MessageBox.show({
            title: title,
            msg: message,
            buttons: Ext.MessageBox.YESNO,
            icon: Ext.MessageBox.QUESTION,
            defaultFocus: null,
            fn: this._createProtectedCallback(callbackFn, scope)
        });
    },

    alert: function(title, message, callbackFn, scope) {
        Ext.MessageBox.show({
            title: title,
            msg: message,
            buttons: Ext.MessageBox.OK,
            icon: Ext.MessageBox.INFO,
            defaultFocus: null,
            fn: this._createProtectedCallback(callbackFn, scope)
        });
    },

    prompt: function(title, message, callbackFn, scope) {
        Ext.MessageBox.show({
            title: title,
            msg: message,
            buttons: Ext.MessageBox.OKCANCEL,
            prompt: true,
            icon: Ext.MessageBox.QUESTION,
            defaultFocus: null,
            fn: this._createProtectedCallback(callbackFn, scope)
        });
    }
});