				me.findPlugin('clearbutton').destroyed = false;
			}
		}
		me.callParent();
	},
	setDisabled: function(disabled) {
		var me = this
			, plugin = me.getPlugins();

		//민대리 2017-06-30
		if (!disabled && !Ext.isIE && me.xtype != "textarea" && me.xtype != "textareafield") {
			11
			if (!me.findPlugin('clearbutton')) {
				me.addPlugin({ ptype: 'clearbutton' });
			} else if (me.findPlugin('clearbutton').destroyed) { //이미 destroyed 된 상태면 풀어줌
				me.findPlugin('clearbutton').destroyed = false;
			}
		} else {
			//민대리 2017-06-29
			if (me.findPlugin('clearbutton')) {
				//me.findPlugin('clearbutton').destroy();
				me.findPlugin('clearbutton').destroyed = true; //destroy() 함수가 해당 속성을 바꿔주지 못하고 있음. 6.0.1 버그?
			}
		}

		this.callParent(arguments);
	},
	setReadOnly: function(readonly) {
		var me = this
			, plugin = me.getPlugins();

		this.callParent(arguments);

		if (!readonly && !Ext.isIE && me.xtype != "textareafield") {
			me.addPlugin({ ptype: 'clearbutton' });
		} else {
			if (me.findPlugin('clearbutton')) me.findPlugin('clearbutton').destroy();
		}
	}
});

