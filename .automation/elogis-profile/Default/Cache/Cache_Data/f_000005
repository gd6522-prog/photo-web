		//마지막 선택한 ROW 인덱스가 없고, 그리드 조회 건수가 있으면, 0번째 ROW 다음에 추가함.
		if ((Util.isNull(me.lastSelectedRowIdx) || me.lastSelectedRowIdx == -1) && me.getStore().getData().length > 0) {
