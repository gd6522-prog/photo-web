	//공지사항 내용
	//헤더 텍스트
	Ext.getCmp('NOTICE_VIEW_PANEL').setTitle(Lang.get('NOTICE_TITLE') + ' : ' + me.getSelectedRowData('NOTI_TITLE'));

	//첨부파일
	ajaxCallback(
		me
		, '/noticeMgmt/searchDetail'
		, { NOTI_SEQ: record.get('NOTI_SEQ') }
		, function(target, data) {
			Ext.getCmp('NOTICE_VIEW').setValue('<table style="height:300px;"><td style="vertical-align:top">' + data.NOTI_CONTENT + '</td></table>');
			/*				setTimeout(function(){
								Ext.getCmp('updatePopupForm').setWidth(Number(Ext.getCmp('updatePopupForm').getWidth())+1);
							},100);*/

		}
	);
	//첨부파일 hidden 여부 - neputne 테마 때문에 hidden 으로 설정함 .
	/*var grid = Ext.getCmp('noticeHeader');
	var orgnm = grid.getSelectedRowData('ORG_ATTACHED_FILE_NM');
	if(!Util.isNull(orgnm)) {
		Ext.getCmp('ATTFILEDOWNLOAD').setHidden(false);
	}else{
		Ext.getCmp('ATTFILEDOWNLOAD').setHidden(true);
	}*/

	var grid = Ext.getCmp('noticeHeader');
	var saveImgUrl = '';
	var themeColor = top.UserInfo.color;
	var theme = top.UserInfo.theme;
	if (theme == 'neptune') {
		themeColor = themeColor.substring(1)
		saveImgUrl = '/view/img/theme/' + theme + '/' + themeColor + '/icons/page_save.png'
	} else {
		saveImgUrl = '/view/img/theme/' + theme + '/icons/page_save.png'
	}

	ajaxCallback(
		me
		, '/noticeMgmt/searchFile'
		, { NOTI_SEQ: grid.getSelectedRowData('NOTI_SEQ') }
		, function(target, data) {
			var downloadFlag = '';
			var fileDraw = '';

			fileDraw += '<div id ="fileArea"><table style="width:98%">';
			if (data.length == 0) {
				fileDraw += '<tr style="height:20px"><td style="width:100%">' + Lang.get('NO_FILE_BOARD') + '</td></tr>'
			} else {

				for (var cnt = 0; cnt < data.length; cnt++) {
					var boardSeq = data[cnt].BOARD_SEQ;
					var fileSeq = data[cnt].FILE_SEQ;
					var fileNm = data[cnt].NAME;
					var fileOnm = data[cnt].CHG_NAME;

					downloadFlag = '<input type="image" height="15px"  ref="down" cnt="' + cnt + '" src="' + saveImgUrl + '"   fileOnmOpt = "' + fileOnm + '" fileNmOpt = "' + fileNm + '" fileSeqOpt = "' + fileSeq + '" boardSeqOpt="' + boardSeq + '">';

					fileDraw += '<tr style="height:25px">'
					//fileDraw +=    '<td style="width:0%">'+data[cnt].INS_PERSON_ID+'</td>'
					fileDraw += '<td style="width:40%">' + data[cnt].INS_DATETIME + '</td>'
					fileDraw += '<td style="width:53%">' + data[cnt].NAME + '</td>'
					fileDraw += '<td style="width:6%">' + downloadFlag + '</td>'
					fileDraw += '</tr>'
				}
			}
			fileDraw += '</table></div>';
			Ext.getCmp('fileField').setValue(fileDraw);

			for (var i = 0; i < Ext.query('input[ref=down]').length; i++) {
				Ext.query('input[ref=down]')[i].onclick = function() {
					//Ext.getCmp('fileField').callAjax({},me);
					var params = {
						WEBROOTPATH : '/data/was/elogis/',
						DIRECTORY: 'BOARD_FILE/',
						FILE_NM: this.getAttribute('fileonmopt'),
						NEW_NM: del_extention(encodeURIComponent(this.getAttribute('filenmopt')))
					};

					Ext.Ajax.request({
						url: '/fileUploadService/fileCheck',
						jsonData: {},
						params: params,
						success: function(conn, response, options, eOpts) {
							query = Ext.Object.toQueryString(params);
							Ext.DomHelper.append(Ext.getBody(), {
								tag: 'iframe',
								frameBorder: 0,
								width: 0,
								height: 0,
								css: 'display:none;visibility:hidden;height:0px;',
								src: '/fileUploadService/fileDownLoad?' + query
							});
						},
						failure: function(conn, response, options, eOpts) {
						}
					});

				}
			}
			Ext.getCmp('scrollArea').updateLayout();
			setTimeout(function() {
				Ext.getCmp('NOTICE_INFO').setWidth(Number(Ext.getCmp('NOTICE_INFO').getWidth()) + 1);
			}, 100);

			var pTag = window.document.getElementById("NOTICE_VIEW_scroll-innerCt");

			pTag.style.overflowX = "auto";
		}
	);
}


function del_extention(filename) {
	var _fileLen = filename.length;
	/** * lastIndexOf('.') * 뒤에서부터 '.'의 위치를 찾기위한 함수 * 검색 문자의 위치를 반환한다. * 파일 이름에 '.'이 포함되는 경우가 있기 때문에 lastIndexOf() 사용 */
	var _lastDot = filename.lastIndexOf('.');
	// 확장자 명만 추출한 후 소문자로 변경
	var _fileExt = filename.substring(0, _lastDot);
	return _fileExt;
}

