	, home: function() {
		try {
			var mainContainer = Ext.getCmp('main-mainContainer');

			if (mainContainer.getComponent('home_tab')) {
				mainContainer.setActiveTab(mainContainer.getComponent('home_tab'));
			} else {
				var addedTab = mainContainer.add({
					title: 'Home',
					id: 'home_tab',
					menuCode: 'mainHome',
					closable: true,
					closeAction: 'destory',
					html: '<iframe id="home_tab_iframe" src="/home_default.jsp" style="height:100%;width:100%;border:0;" frameBorder="0"></iframe>'
				});
				mainContainer.setActiveTab(addedTab);
				mainContainer.addCnt++;
			}
		}
		catch (err) {
			Ext.Msg.alert('Error', 'Fail to create tab...');
			throw err;
		}
	},
	download: function(params) {
		var me = this;

		ajaxCallback(
			me
			, 'fileUploadService/fileCheck'
			, params
			, function(target, json) {
				query = Ext.Object.toQueryString(params);

				Ext.DomHelper.append(Ext.getBody(), {
					tag: 'iframe',
					frameBorder: 0,
					width: 0,
					height: 0,
					css: 'display:none;visibility:hidden;height:0px;',
					src: 'fileUploadService/fileDownLoad?' + query
				});
			}
		);
	},
