	$.fn.onOnlyNumber = function() {
		$(this).on({
			'keydown.OnlyNumber' : function(e) {
				var keyCode = e.which ? e.which : e.keyCode;

				if ((keyCode >= 48 && keyCode <= 57) || (keyCode >= 96 && keyCode <= 105) || keyCode == 8 || keyCode == 46 || keyCode == 37 || keyCode == 39  || keyCode == 13) {
					return true;
				} else {
					return false;
				}
			},
			'keyup.OnlyNumber' : function(e) {
				var keyCode = e.which ? e.which : e.keyCode;

				if (keyCode == 8 || keyCode == 46 || keyCode == 37 || keyCode == 39) {
					return;
				} else {
					e.target.value = e.target.value.replace(/[^0-9]/g, '');
				}
			}
		});
	};

