/**
 * 창을 연다.
 *
 * @author HKH
 * @param name
 *            {String}
 * @param url
 *            {String}
 * @param options
 *            {Object}
 * @returns
 */
function openWindow(name, url, options) {
	name = encodeURI(name);
	options = $.extend({
		centerBrowser : 0,
		centerScreen : 0,
		left : 0,
		top : 0,
		location : 0,
		menubar : 0,
		resizable : 1,
		scrollbars : 0,
		status : 0,
		toolbar : 0,
		width : 500,
		height : 500
	}, options || {});

	var windowFeatures = 'height=' + options.height + ',width=' + options.width + ',toolbar=' + options.toolbar + ',scrollbars=' + options.scrollbars
			+ ',status=' + options.status + ',resizable=' + options.resizable + ',location=' + options.location + ',menuBar=' + options.menubar;

	var centeredY = null;
	var centeredX = null;

	var windowObj = null;

	if (options.centerBrowser) {
		if ($.browser && $.browser.msie) {
			centeredY = (window.screenTop - 120) + ((((document.documentElement.clientHeight + 120) / 2) - (options.height / 2)));
			centeredX = window.screenLeft + ((((document.body.offsetWidth + 20) / 2) - (options.width / 2)));
		} else {
			centeredY = window.screenY + (((window.outerHeight / 2) - (options.height / 2)));
			centeredX = window.screenX + (((window.outerWidth / 2) - (options.width / 2)));
		}

		windowObj = window.open(url, name, windowFeatures + ',left=' + centeredX + ',top=' + centeredY);
	} else if (options.centerScreen) {
		centeredY = (screen.height - options.height) / 2;
		centeredX = (screen.width - options.width) / 2;

		windowObj = window.open(url, name, windowFeatures + ',left=' + centeredX + ',top=' + centeredY);
	} else {
		windowObj = window.open(url, name, windowFeatures + ',left=' + options.left + ',top=' + options.top);
	}

	if (windowObj) { // 팝업이 존재하면
		windowObj.focus();
	}

	return windowObj;
}

