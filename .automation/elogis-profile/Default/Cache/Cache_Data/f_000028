(function($) {
	/**
	 * 문자열 포멧팅
	 *
	 * @author HKH
	 * @param source
	 *            {String)
	 * @param params
	 *            {Array|String}
	 * @returns
	 */
	$.format = function(source, params) {
		if (params === undefined) {
			return source;
		}
		if (arguments.length > 2 && params.constructor != Array) {
			params = $.makeArray(arguments).slice(1);
		}
		if (params.constructor != Array) { // 배열이 아니면
			params = [ params ];
		}

		$.each(params, function(index, value) {
			source = source.replace(new RegExp("\\{" + index + "\\}", "g"), value);
		});

		return source;
	};

	/**
	 * serialize
	 *
	 * @author HKH
	 * @returns
	 */
	$.fn.serializeObject = function() {
		var result = {};

		$.each(this.serializeArray(), function(index, value) {
			if (this.name in result) {
				if (result[this.name].constructor != Array) { // 배열이 아니면
					result[this.name] = [ this.value ];
				}

				result[this.name].push(this.value);
			} else {
				result[this.name] = this.value;
			}
		});

		return result;
	};

	/**
	 * deserialize
	 *
	 * @author HKH
	 * @param serialize
	 *            {String}
	 * @param options
	 *            {Object}
	 * @returns
	 */
	$.deserialize = function(serialize, options) {
		var result = {}, options = options || {};

		$.each(serialize ? serialize.split(/&amp;|&/i) : [], function(index, value) {
			var pairs = this.split('=');
			var key = decodeURIComponent(pairs[0]), value = decodeURIComponent(pairs[1]);

			if (!options.except || options.except.indexOf(key) == -1) {
				var matches = key.match(/^(\w+)\[(\w+)\]$/);

				if (matches) {
					if (!(matches[1] in result)) {
						result[matches[1]] = {};
					}

					result[matches[1]][matches[2]] = value;
				} else {
					result[key] = value;
				}
			}
		});

		return result;
	};

	/**
	 * deserialize
	 *
	 * @author HKH
	 * @param options
	 *            {Object}
	 * @returns
	 */
	$.fn.deserialize = function(options) {
		return $.deserialize($(this).serialize(), options);
	};

 	/**
