/**
 * form submit을 발생 시킨다.
 *
 * @author HKH
 * @param action
 *            {String}
 * @param paramMap
 *            {Object}
 * @param options
 *            {Object}
 */
function formSubmit(action, paramMap, options) {
	var $form = $('<form>').attr($.extend({
		method : 'post'
	}, options || {}, {
		action : action
	}));

	for ( var key in paramMap) {
		try {
			$.each($.makeArray(paramMap[key]), function(index, value) {
				$form.append($('<input>').attr({
					name : key,
					type : 'hidden'
				}).val(typeof value === 'object' ? JSON.stringify(value) : value));
			});
		} catch (e) {
			log(e);
		}
	}

	$form.appendTo(document.body).submit().remove();
}
