	var doAppendLine = function (objSheet) {
		var retVal = true;

		if (objSheet.GetEtcData("queryInfo") != null){

			if(objSheet.GetEtcData("requestURI") != null && objSheet.GetEtcData("requestURI") != 'undefined' &&objSheet.GetEtcData("requestURI") != 'null'){
				var preQuery = objSheet.GetEtcData("requestURI");
				preQuery = preQuery.substring(preQuery.indexOf("?") + 1);

				var nowQuery = FormQueryStringEnc(document.form_filter)+"&"
				nowQuery = decodeURIComponent(nowQuery); //인코딩한 데이터 되돌림

				//nowQuery = nowQuery.replace(/%7C/g, "|"); //디코딩후 필요 없음

				var preQueryList = preQuery.split("&");
				var nowQueryList = nowQuery.split("&");
				var nEquals = 0;

				for(var i=0; i< preQueryList.length; i++){
					for(var j=0; j<nowQueryList.length; j++){
						if(preQueryList[i] == nowQueryList[j]){
							nEquals++;
						}
					}
				}

				if(nEquals == preQueryList.length){
					objSheet.DataInsert(0);
				}else{
					alert('데이터 조회 조건이 같지 않습니다.');
					retVal = false;
				}
			}else{
				objSheet.DataInsert(0);
			}
		}
		else{
			alert('데이터 조회후 입력이 가능합니다.');
			retVal = false;
		}

		return retVal;
	};



