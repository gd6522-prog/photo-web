		/**
		 * 프론트엔드와 백엔드 양쪽에서 모두 중복 검사
		 *
		 * @author HKH
		 * @param objSheet
		 *            {Object} IBSheet Object
		 * @param url
		 *            {String} 요청 URL
		 * @param keyName
		 *            {String} 키에 해당하는 SaveName을 구분자 '|'로 연결한 문자열
		 */
		doDupCheck : function(objSheet, url, keyName) {
			if (objSheet.RowCount('I') == 0) { // 입력 데이터가 없으면
				return true;
			}

			var fnDupCallback = function(idx, seq) {

				if(idx == null && seq == null){
					alert('(노선명/차량번호)중복값이 있습니다.');
				}else{
					objSheet.SetSelectRow(idx);
					alert(seq + '번째 줄에 중복값이 있습니다.');
				}
			};

			var idx = objSheet.ColValueDup(keyName);

			if (idx != -1) { // 중복 데이터가 존재하면
				fnDupCallback(idx, objSheet.GetCellValue(idx, 'SEQ'));

				return false;
			}

			var result = false;

			var keyNames = keyName.split('|');

			common.doAjax(url, {
				save_data : $.map(objSheet.FindStatusRow('I').split(';'), function(value, index) {
					var rowData = objSheet.GetRowData(value);

					return keyNames.reduce(function(total, key) {
						total.push(rowData[key]);

						return total;
					}, [ value, rowData.SEQ ]).join(':');
				}).join('|')
			}, function(resData, textStatus, jqXHR) {
				resData = resData.XDataMap;
				switch (resData.RESULT_CODE) {
				case '0': // 정상
					return result = true;
				case '1': // 중복
					fnDupCallback(resData.IDX, resData.SEQ);

					return result = false;
				default:
					break;
				}
			}, {
				async : false,
				blockEl : window
			});

			return result;
		},


