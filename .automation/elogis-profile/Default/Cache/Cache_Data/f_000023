/***** ( TABLE ) *****/
/* ( table - fixed[fixed column] ) */
table.fixed {table-layout:fixed}

/* ( table-primary ) */
.table-primary {
	table-layout:auto;
	border-top:1px solid #8cc4f6;
}
.table-primary tr:last-child th, .table-primary tr:last-child td {
	border-bottom:1px solid #8cc4f6;
}
.table-primary th, .table-primary td {
	padding: 6px 0 6px 6px;
	border-bottom:1px solid #c5e2f3;
}
.table-primary th {
	padding-left: 9px;
	padding-top: 12px;
	font-weight:700;
	background-color:#e1eefb;
	text-align:left;
	letter-spacing: -1px;
	vertical-align: top;
	border-bottom:1px solid #bddffc;
}

/* ( table-frame : 占쎈뼊占쎈떄 占쎈늄占쎌쟿占쎌뿫 占쎌뒠占쎈즲占쎌벥 占쎈�믭옙�뵠�뇡占� ) */
.table-frame {width:100%;table-layout:fixed}
table .table-frame th, table .table-frame td {
	padding: 2px;
	background-color:transparent;
	border:0;
} 
table .table-frame th:first-child, 
table .table-frame td:first-child 		{padding-left:0;}
table .table-frame tr:first-child td  	{padding-top:0;} 
table .table-frame tr:last-child td  	{padding-bottom:0;} 
table .table-frame tr td:last-child		{padding-right:0;}
.table-frame td 						{ border:0 none;}
.table-frame .th-step,
.table-frame .th-empty {
	background-color:transparent;
	border:0 none;
}
.table-frame th, .table-frame td {height: auto;}
.table-frame.td-first tr td:first-child {padding-left:0}
.table-frame td:last-child:first-child {border-right:0}
table .table-frame button  {
	margin-left:0;
} 



