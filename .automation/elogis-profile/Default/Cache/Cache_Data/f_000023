/* Tooltip text */
.tooltip .tooltiptext {
    visibility: hidden;
    width: 60px;
    background-color: #599af8;
    color: #fff;
    text-align: center;
    padding: 5px;
    border-radius: 6px;
 
    /* Position the tooltip text - see examples below! */
    position: absolute;
    z-index: 1000;
    bottom: 25px;
    left: 50%; 
    margin-left: -30px; /* Use half of the width (120/2 = 60), to center the tooltip */
}
.tooltip a:hover .tooltiptext { /* Show the tooltip text when you mouse over the tooltip container */
    visibility: visible;
}
.tooltip a:hover button {background: url(../images/common/ic-logout_on.png) top left no-repeat; }


