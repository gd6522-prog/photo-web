/***** ( TAB ) *****/
.tabSec {
	overflow:hidden;
}
.tab-item {
	position: relative; 
	height:28px;
	z-index: 1;
}
.tab-item li {
	position:relative;
	float:left;
	padding: 7px 15px 5px;
	margin-right:-1px;
	border: 1px solid #8ec5f4; 
	border-bottom-color: #e1eefb; 
	background-color: #e1eefb;
